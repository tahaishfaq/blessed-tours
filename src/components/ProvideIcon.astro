---
import type { ProvideCard } from '../data/what-we-provide';

interface Props {
	name: ProvideCard['icon'];
	class?: string;
}

const { name, class: className = 'size-6 sm:size-7' } = Astro.props;
---

<svg
	class={className}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.5"
	aria-hidden="true"
>
	{
		name === 'hotel' && (
			<>
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 20V8l8-4 8 4v12" />
				<path stroke-linecap="round" d="M4 20h16M9 20v-4h6v4" />
				<path stroke-linecap="round" d="M9 10h.01M15 10h.01" />
			</>
		)
	}
	{
		name === 'flight' && (
			<>
				<path stroke-linecap="round" stroke-linejoin="round" d="M2 16l20-8-8 8 2 6-4-2-6 4-2-6z" />
			</>
		)
	}
	{
		name === 'transport' && (
			<>
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 16h16M6 16V8h12v8" />
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 12h12" />
				<circle cx="7.5" cy="16" r="1.5" />
				<circle cx="16.5" cy="16" r="1.5" />
			</>
		)
	}
	{
		name === 'visa' && (
			<>
				<rect x="5" y="3" width="14" height="18" rx="2" />
				<circle cx="12" cy="11" r="2.5" />
				<path stroke-linecap="round" d="M8 17h8" />
			</>
		)
	}
</svg>
