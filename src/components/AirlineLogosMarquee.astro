---
const airlineLogos = [
	{ name: 'Gulf Air', file: 'gulf-air-seeklogo.png' },
	{ name: 'Emirates', file: 'emirates-airlines-seeklogo.png' },
	{ name: 'Etihad Airways', file: 'etihad-airways-seeklogo.png' },
	{ name: 'Oman Air', file: 'oman-air-seeklogo.png' },
	{ name: 'British Airways', file: 'british-airways-seeklogo.png' },
	{ name: 'Middle East Airlines', file: 'mea-middle-east-airlines-seeklogo.png' },
	{ name: 'Virgin Atlantic', file: 'virgin-atlantic-seeklogo.png' },
	{ name: 'Thai Airways', file: 'thai-airways-seeklogo.png' },
	{ name: 'Wizz Air', file: 'wizz-air-seeklogo.png' },
	{ name: 'Saudi Arabian Airlines', file: 'saudi-arabian-airlines-seeklogo.png' },
	{ name: 'Pakistan International Airlines', file: 'pia-pakistan-international-airlines-seeklogo.png' },
	{ name: 'Pegasus Airlines', file: 'pegasus-airlines-seeklogo.png' },
	{ name: 'Turkish Airlines', file: 'thy-turk-hava-yollari-seeklogo.png' },
	{ name: 'Lufthansa', file: 'lufthansa-seeklogo.png' },
	{ name: 'Qatar Airways', file: 'qatar-airways-seeklogo.png' },
	{ name: 'Royal Jordanian', file: 'royal-jordanian-airlines-seeklogo.png' },
	{ name: 'KLM Royal Dutch Airlines', file: 'klm-royal-dutch-airlines-seeklogo.png' },
	{ name: 'Air Peace', file: 'air-peace-seeklogo.png' },
	{ name: 'Batik Air', file: 'batik-air-seeklogo.png' },
];
---

<section class="section-block w-full px-0 pt-0 pb-0" aria-labelledby="airline-logos-heading">
	<div class="relative w-full max-w-none" data-motion-root data-motion-trigger="inview">
		<div
			class="relative overflow-hidden pt-5 pb-1 sm:pt-6 sm:pb-2"
			data-motion-item="up"
			data-motion-delay="0"
		>
			<div class="mb-5 px-4 text-center sm:px-6 lg:px-8">
				<p class="mb-3 inline-flex rounded-full border border-white/15 bg-white/[0.06] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-wider text-gold-400 backdrop-blur-sm transition-colors duration-300 hover:border-gold-500/35 hover:bg-gold-500/10 sm:mb-4">
					Our partners
				</p>
				<h2 id="airline-logos-heading" class="font-display text-3xl leading-[1.12] tracking-tight text-ink-50 sm:text-4xl lg:text-[2.75rem] lg:leading-[1.1]">
					Our Airline Partners
				</h2>
			</div>

			<div class="airline-marquee group relative overflow-hidden" aria-label="Airline logos">
				<div class="airline-marquee__track flex w-max will-change-transform group-hover:[animation-play-state:paused]">
					{
						[0, 1].map((groupIndex) => (
							<div class="flex shrink-0 items-center gap-5 px-3 sm:gap-6 sm:px-4 lg:gap-7" aria-hidden={groupIndex === 1}>
								{airlineLogos.map((logo) => (
									<div class="group/logo grid h-24 w-40 shrink-0 place-items-center px-4 py-3 transition-transform duration-300 hover:scale-[1.03] sm:h-28 sm:w-48 sm:px-5 sm:py-4 lg:h-32 lg:w-56">
										<img
											src={`/images/Airline%20Logos/${logo.file}`}
											alt={`${logo.name} logo`}
											class="max-h-14 w-auto max-w-full object-contain opacity-100 transition-transform duration-300 group-hover/logo:scale-[1.04] sm:max-h-16 lg:max-h-[4.5rem]"
											loading="lazy"
											decoding="async"
										/>
									</div>
								))}
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.airline-marquee__track {
		animation: airline-marquee-scroll 72s linear infinite;
		transform: translate3d(0, 0, 0);
	}

	@keyframes airline-marquee-scroll {
		from {
			transform: translate3d(0, 0, 0);
		}

		to {
			transform: translate3d(-50%, 0, 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.airline-marquee__track {
			animation: none;
		}
	}
</style>
