---
import type { FaqItem } from '../data/faq';
import { faqAside, faqHeading, faqImage } from '../data/faq';
import { phone, whatsapp } from '../data/navigation';

interface Props {
	items: FaqItem[];
	heading?: string;
	image?: { src: string; alt: string };
}

const { items, heading = faqHeading, image = faqImage } = Astro.props;

---

<section
	class="section-block section-block--divider px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-28"
	aria-labelledby="faq-heading"
>
	<div class="relative mx-auto max-w-7xl" data-motion-root data-motion-trigger="inview">
		<div
			class="mb-10 grid grid-cols-1 gap-8 lg:mb-14 lg:grid-cols-[1fr_min(22rem,32%)] lg:items-end lg:gap-12"
		>
			<div class="max-w-3xl">
				<p
					class="mb-4 inline-flex rounded-full border border-white/12 bg-white/[0.05] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-wider text-gold-400 backdrop-blur-sm"
					data-motion-item="up"
					data-motion-delay="0"
				>
					FAQ
				</p>
				<h2
					id="faq-heading"
					class="font-display text-3xl leading-[1.12] tracking-tight text-ink-50 sm:text-4xl lg:text-[2.65rem] lg:leading-[1.08]"
					data-motion-item="up"
					data-motion-delay="75"
				>
					{heading}
				</h2>
			</div>

			<aside
				class="lg:pb-1 lg:text-right"
				data-motion-item="up"
				data-motion-delay="150"
			>
				<p class="font-sans text-base font-semibold text-ink-50 sm:text-lg">
					{faqAside.title}
				</p>
				<p class="mt-2 font-sans text-sm leading-relaxed text-ink-400 sm:text-base">
					{faqAside.body}
				</p>
				<div class="mt-4 flex flex-wrap gap-3 lg:justify-end">
					<a
						href={whatsapp.href}
						class="inline-flex items-center gap-2 rounded-full border border-gold-500/35 bg-gold-500/10 px-4 py-2 font-sans text-sm font-semibold text-gold-400 transition-colors hover:bg-gold-500/18"
						target="_blank"
						rel="noopener noreferrer"
					>
						{whatsapp.label}
					</a>
					<a
						href={phone.href}
						class="inline-flex items-center rounded-full border border-white/12 bg-white/[0.05] px-4 py-2 font-sans text-sm font-semibold text-ink-50 transition-colors hover:border-white/20 hover:bg-white/[0.08]"
					>
						{phone.label}
					</a>
				</div>
			</aside>
		</div>

		<div
			class="faq-content-grid grid grid-cols-1 gap-8 lg:grid-cols-2 lg:items-stretch lg:gap-10 xl:gap-14"
			data-faq-grid
		>
			<div
				class="faq-accordion order-2 flex flex-col gap-3 sm:gap-3.5 lg:order-1"
				data-faq-accordion
				data-motion-item="up"
				data-motion-delay="175"
			>
				{
					items.map((item, i) => (
						<details
							class="faq-item group rounded-2xl border border-white/10 bg-white/[0.04] shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] backdrop-blur-sm transition-[border-color,box-shadow] duration-300 open:border-gold-500/30 open:bg-white/[0.06] open:shadow-[0_16px_40px_-24px_rgba(0,0,0,0.5)] sm:rounded-[1.35rem]"
							open={i === 0}
							data-faq-index={i}
						>
							<summary class="faq-item__summary flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 sm:px-6 sm:py-[1.15rem]">
								<span class="font-sans text-sm font-semibold leading-snug text-ink-50 sm:text-[0.95rem]">
									{item.question}
								</span>
								<span
									class="faq-item__chevron inline-flex size-8 shrink-0 items-center justify-center rounded-full border border-gold-500/25 bg-gold-500/10 text-gold-400 transition-transform duration-300 group-open:rotate-180"
									aria-hidden="true"
								>
									<svg
										class="size-4"
										viewBox="0 0 20 20"
										fill="currentColor"
										aria-hidden="true"
									>
										<path
											fill-rule="evenodd"
											d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.24 4.5a.75.75 0 01-1.08 0l-4.24-4.5a.75.75 0 01.02-1.06z"
											clip-rule="evenodd"
										/>
									</svg>
								</span>
							</summary>
							<div class="faq-item__answer border-t border-white/[0.06] px-5 pb-5 sm:px-6 sm:pb-6">
								<p class="pt-3 font-sans text-sm leading-relaxed text-ink-400">{item.answer}</p>
							</div>
						</details>
					))
				}
			</div>

			<div
				class="faq-visual relative order-1 overflow-hidden rounded-[2rem] border border-white/10 shadow-[0_24px_60px_-24px_rgba(0,0,0,0.65)] sm:rounded-[2.25rem] lg:order-2 lg:h-full lg:min-h-0"
				data-faq-visual
				data-motion-item="scale"
				data-motion-delay="100"
			>
				<div
					class="pointer-events-none absolute inset-0 z-10 bg-gradient-to-t from-black/50 via-transparent to-black/10"
					aria-hidden="true"
				></div>
				<img
					src={image.src}
					alt={image.alt}
					class="faq-visual__img aspect-[4/5] h-full w-full object-cover sm:aspect-[5/6]"
					width="600"
					height="750"
					loading="lazy"
					decoding="async"
				/>
			</div>
		</div>
	</div>
</section>

<script>
	function syncFaqImageHeight() {
		const accordion = document.querySelector<HTMLElement>('[data-faq-accordion]');
		const visual = document.querySelector<HTMLElement>('[data-faq-visual]');
		if (!accordion || !visual) return;

		if (window.matchMedia('(min-width: 1024px)').matches) {
			visual.style.height = `${accordion.offsetHeight}px`;
		} else {
			visual.style.removeProperty('height');
		}
	}

	function initFaqAccordion() {
		const root = document.querySelector<HTMLElement>('[data-faq-accordion]');
		if (!root || root.dataset.faqReady === 'true') return;

		const items = root.querySelectorAll<HTMLDetailsElement>('.faq-item');
		const first = items[0];

		items.forEach((item) => {
			const index = Number(item.dataset.faqIndex ?? -1);

			item.addEventListener('toggle', () => {
				if (index === 0 && !item.open) {
					item.open = true;
					return;
				}

				if (!item.open) {
					syncFaqImageHeight();
					return;
				}

				items.forEach((other) => {
					const otherIndex = Number(other.dataset.faqIndex ?? -1);
					if (other !== item && otherIndex !== 0) other.open = false;
				});

				requestAnimationFrame(syncFaqImageHeight);
			});
		});

		if (first) first.open = true;

		const resizeObserver = new ResizeObserver(() => syncFaqImageHeight());
		resizeObserver.observe(root);
		window.addEventListener('resize', syncFaqImageHeight);

		requestAnimationFrame(syncFaqImageHeight);

		root.dataset.faqReady = 'true';
	}

	initFaqAccordion();
	document.addEventListener('astro:page-load', initFaqAccordion);
</script>

<style>
	.faq-item__summary::-webkit-details-marker {
		display: none;
	}

	.faq-item__summary::marker {
		content: '';
	}

	.faq-item__answer {
		animation: faq-answer-in 0.35s cubic-bezier(0.33, 1, 0.68, 1);
	}

	@keyframes faq-answer-in {
		from {
			opacity: 0;
			transform: translateY(-4px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (min-width: 1024px) {
		.faq-visual__img {
			position: absolute;
			inset: 0;
			height: 100%;
			width: 100%;
			aspect-ratio: auto;
		}

		.faq-visual {
			position: relative;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.faq-item__answer {
			animation: none;
		}

		.faq-item__chevron {
			transition: none;
		}
	}
</style>
