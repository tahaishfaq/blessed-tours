---
import type { BookingStep } from '../data/booking-process';
import { bookingProcessIntro } from '../data/booking-process';
import BookingStepIcon from './BookingStepIcon.astro';
import SectionHeaderFrame from './SectionHeaderFrame.astro';

interface Props {
	steps: BookingStep[];
	intro?: string;
}

const { steps, intro = bookingProcessIntro } = Astro.props;

const stepDelays = ['150', '225', '300', '375'] as const;
const stepNums = ['01', '02', '03', '04'] as const;
---

<section
	class="section-block section-block--divider px-4 pt-5 pb-5 sm:px-6 sm:pt-6 sm:pb-6 lg:px-8 lg:pt-7 lg:pb-7"
	aria-labelledby="booking-process-heading"
>
	<div class="relative mx-auto max-w-7xl" data-motion-root data-motion-trigger="inview">
		<SectionHeaderFrame
			eyebrow="How it works"
			heading="Easy Booking Process"
			headingId="booking-process-heading"
			description={intro}
			align="center"
			class="lg:mb-7"
		/>

		<ol
			class="booking-timeline relative grid grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-5 lg:grid-cols-4 lg:gap-6"
		>
			{
				steps.map((item, i) => (
					<li
						class="booking-timeline__step group relative"
						data-motion-item="scale"
						data-motion-delay={stepDelays[i] ?? '375'}
					>
						<article
							class="relative z-[1] flex h-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.04] p-5 pb-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] backdrop-blur-sm transition-[border-color,transform,box-shadow] duration-500 ease-[cubic-bezier(0.33,1,0.68,1)] hover:border-gold-500/30 hover:shadow-[0_20px_40px_-20px_rgba(0,0,0,0.45)] sm:p-6"
						>
							<span
								class="pointer-events-none absolute top-3 right-3 font-display text-[2.75rem] leading-none text-gold-500/[0.09] select-none sm:-top-3 sm:right-4 sm:text-5xl sm:text-gold-500/[0.12] lg:text-6xl"
								aria-hidden="true"
							>
								{stepNums[i]}
							</span>

							<div class="relative mb-4 flex items-center sm:mb-5">
								<span
									class="booking-timeline__icon inline-flex size-11 items-center justify-center rounded-xl border border-white/10 bg-white/[0.04] text-gold-400 transition-transform duration-500 group-hover:scale-105"
									aria-hidden="true"
								>
									<BookingStepIcon name={item.icon} class="size-5" />
								</span>
							</div>

							<h3 class="relative max-w-[calc(100%-3.5rem)] font-display text-lg leading-tight text-ink-50 sm:max-w-none sm:text-xl">
								{item.title}
							</h3>
							<p class="relative mt-2.5 flex-1 font-sans text-sm leading-relaxed text-ink-400">
								{item.description}
							</p>
						</article>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	/* Connectors on tablet + desktop only (no lines on mobile) */
	@media (min-width: 640px) and (max-width: 1023px) {
		.booking-timeline__step:nth-child(odd)::after {
			content: '';
			position: absolute;
			top: 2.875rem;
			left: 4.25rem;
			width: calc(100% - 4.25rem + 1.25rem);
			height: 1px;
			transform: translateY(-50%);
			background: linear-gradient(
				90deg,
				hsl(36 75% 65% / 0.55),
				hsl(36 75% 65% / 0.22)
			);
			pointer-events: none;
			z-index: 1;
		}
	}

	@media (min-width: 1024px) {
		.booking-timeline__step:not(:last-child)::after {
			content: '';
			position: absolute;
			top: 2.875rem;
			left: 4.25rem;
			width: calc(100% - 4.25rem + 3rem);
			height: 1px;
			transform: translateY(-50%);
			background: linear-gradient(
				90deg,
				hsl(36 75% 65% / 0.55),
				hsl(36 75% 65% / 0.22)
			);
			pointer-events: none;
			z-index: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.booking-timeline__step article {
			transition: border-color 0.2s ease;
		}

		.booking-timeline__step article:hover {
			transform: none;
		}
	}
</style>
