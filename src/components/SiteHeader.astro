---
import Logo from './Logo.astro';
import { mainNav, phone, whatsapp } from '../data/navigation';

interface Props {
	/** Overlay hero only — scrolls away with hero (not sticky) */
	overlay?: boolean;
}

const { overlay = false } = Astro.props;

const pathname = Astro.url.pathname;

function isActive(href: string) {
	if (href === '/') return pathname === '/';
	return pathname.startsWith(href);
}
---

<header
	class:list={[
		'z-50 w-full',
		overlay
			? 'absolute top-0 left-0 bg-transparent'
			: 'sticky top-0 border-b border-ink-800 bg-black',
	]}
	data-site-header
	data-motion-root
	data-motion-trigger="load"
>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="flex h-16 items-center justify-between gap-2 sm:gap-3 lg:h-[4.5rem] lg:gap-4">
			<div class="min-w-0 shrink" data-motion-item="down" data-motion-delay="0">
				<Logo class="shrink-0" />
			</div>

			<nav
				class="hidden min-w-0 flex-1 items-center justify-center gap-2.5 lg:flex lg:gap-3 xl:gap-6"
				aria-label="Main"
			>
				{
					mainNav.map((item, index) =>
						item.children ? (
							<div class="group relative">
								<a
									href={item.href}
									class:list={[
										'nav-link gap-1 py-2',
										isActive(item.href) && 'nav-link--active',
									]}
									data-motion-item="down"
									data-motion-delay={String(75 + index * 50)}
									aria-haspopup="true"
									aria-expanded="false"
								>
									{item.label}
									<svg
										class="size-3.5 opacity-80"
										viewBox="0 0 20 20"
										fill="currentColor"
										aria-hidden="true"
									>
										<path
											fill-rule="evenodd"
											d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.24 4.5a.75.75 0 01-1.08 0l-4.24-4.5a.75.75 0 01.02-1.06z"
											clip-rule="evenodd"></path>
									</svg>
								</a>
								<div
									class="invisible absolute top-full left-1/2 z-50 min-w-[15rem] -translate-x-1/2 pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
								>
									<ul
										class="overflow-hidden rounded-md border border-ink-100 bg-white py-1 shadow-xl"
										role="menu"
									>
										{item.children.map((child) => (
											<li role="none">
												<a
													href={child.href}
													class:list={[
														'block px-4 py-2.5 font-sans text-sm text-ink-800 transition-colors hover:bg-ink-50 hover:text-gold-600',
														isActive(child.href) && 'text-gold-600',
													]}
													role="menuitem"
												>
													{child.label}
												</a>
											</li>
										))}
									</ul>
								</div>
							</div>
						) : (
							<a
								href={item.href}
								class:list={['nav-link py-2', isActive(item.href) && 'nav-link--active']}
								data-motion-item="down"
								data-motion-delay={String(75 + index * 50)}
							>
								{item.label}
							</a>
						),
					)
				}
			</nav>

			<a
				href={phone.href}
				class="inline-flex size-10 shrink-0 items-center justify-center rounded-md border border-white/20 text-gold-500 transition-colors hover:border-gold-500/50 hover:bg-white/5 lg:hidden"
				aria-label={`Call ${phone.label}`}
			>
				<svg
					class="size-5"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.75"
					aria-hidden="true"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
					></path>
				</svg>
			</a>

			<div class="hidden shrink-0 items-center gap-4 xl:gap-5 lg:flex">
				<a
					href={whatsapp.href}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 font-sans text-sm font-semibold text-[#25D366] transition-opacity hover:opacity-85"
					data-motion-item="down"
					data-motion-delay="450"
				>
					<svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path
							d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
						></path>
					</svg>
					<span class="hidden xl:inline">{whatsapp.label}</span>
				</a>
				<a
					href={phone.href}
					class="inline-flex items-center gap-2 font-sans text-sm font-semibold text-white transition-colors hover:text-gold-400"
					data-motion-item="down"
					data-motion-delay="525"
				>
					<svg
						class="size-5 text-gold-500"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.75"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
						></path>
					</svg>
					<span class="hidden xl:inline">{phone.label}</span>
				</a>
			</div>

			<button
				type="button"
				class="inline-flex size-10 shrink-0 items-center justify-center rounded-md border border-white/20 text-white transition-colors hover:border-gold-500/50 hover:bg-white/5 lg:hidden"
				aria-label="Open menu"
				aria-expanded="false"
				data-menu-toggle
			>
				<svg class="size-6" data-menu-icon-open viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
				</svg>
				<svg class="hidden size-6" data-menu-icon-close viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
		</div>
	</div>

	<div
		class="mobile-menu-backdrop fixed inset-0 z-40 hidden bg-black/50 backdrop-blur-[2px] lg:hidden"
		data-mobile-backdrop
		aria-hidden="true"
	></div>

	<div
		class="mobile-menu-wrapper pointer-events-none fixed inset-x-0 top-16 z-50 hidden px-3 pt-2 sm:px-4 lg:hidden"
		data-mobile-menu-wrapper
	>
		<div
			class="mobile-menu-panel relative mx-auto max-w-lg overflow-hidden rounded-2xl border border-white/25 bg-white/[0.08] shadow-[0_8px_40px_rgba(0,0,0,0.45),inset_0_1px_0_rgba(255,255,255,0.14)] backdrop-blur-2xl"
			data-mobile-menu
		>
			<div
				class="pointer-events-none absolute inset-0 rounded-2xl bg-gradient-to-br from-white/[0.14] via-white/[0.04] to-transparent"
				aria-hidden="true"
			></div>
			<div
				class="pointer-events-none absolute top-0 right-6 left-6 h-px bg-gradient-to-r from-transparent via-white/40 to-transparent"
				aria-hidden="true"
			></div>

			<nav
				class="relative max-h-[min(28rem,calc(100dvh-6rem))] space-y-1 overflow-y-auto overscroll-contain px-4 py-4 sm:px-5 sm:py-5"
				aria-label="Mobile"
			>
			{
				mainNav.map((item) =>
					item.children ? (
						<details class="group/details">
							<summary
								class:list={[
									'flex cursor-pointer list-none items-center justify-between py-2.5 font-sans text-sm font-semibold text-white marker:content-none',
									isActive(item.href) && 'text-gold-500',
								]}
							>
								{item.label}
								<svg
									class="size-4 transition-transform group-open/details:rotate-180"
									viewBox="0 0 20 20"
									fill="currentColor"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.24 4.5a.75.75 0 01-1.08 0l-4.24-4.5a.75.75 0 01.02-1.06z"
										clip-rule="evenodd"></path>
								</svg>
							</summary>
							<ul class="mb-2 space-y-0.5 border-l border-white/15 pl-4">
								{item.children.map((child) => (
									<li>
										<a
											href={child.href}
											class:list={[
												'block py-2 font-sans text-sm text-white/80 hover:text-gold-400',
												isActive(child.href) && 'text-gold-500',
											]}
										>
											{child.label}
										</a>
									</li>
								))}
							</ul>
						</details>
					) : (
						<a
							href={item.href}
							class:list={[
								'nav-link-mobile py-2.5',
								isActive(item.href) && 'nav-link-mobile--active',
							]}
						>
							{item.label}
						</a>
					),
				)
			}
			<div class="mt-4 flex flex-col gap-3 border-t border-white/10 pt-4">
				<a
					href={whatsapp.href}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 font-sans text-sm font-semibold text-[#25D366]"
				>
					<svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path
							d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
						></path>
					</svg>
					{whatsapp.label}
				</a>
				<a
					href={phone.href}
					class="inline-flex items-center gap-2 font-sans text-sm font-semibold text-white"
				>
					<svg
						class="size-5 text-gold-500"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.75"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
						></path>
					</svg>
					{phone.label}
				</a>
			</div>
		</nav>
		</div>
	</div>
</header>

<style>
	.mobile-menu-backdrop {
		opacity: 0;
		transition: opacity 0.45s cubic-bezier(0.33, 1, 0.68, 1);
	}

	.mobile-menu-backdrop.is-open {
		opacity: 1;
	}

	.mobile-menu-panel {
		opacity: 0;
		transform: translateY(-0.75rem) scale(0.98);
		transition:
			opacity 0.45s cubic-bezier(0.33, 1, 0.68, 1),
			transform 0.45s cubic-bezier(0.33, 1, 0.68, 1);
	}

	.mobile-menu-wrapper.is-open .mobile-menu-panel {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	@media (prefers-reduced-motion: reduce) {
		.mobile-menu-backdrop,
		.mobile-menu-panel {
			transition: none;
		}

		.mobile-menu-panel {
			transform: none;
		}
	}
</style>

<script>
	const MENU_TRANSITION_MS = 450;

	function initSiteHeader(header: HTMLElement) {
		const toggle = header.querySelector<HTMLButtonElement>('[data-menu-toggle]');
		const menu = header.querySelector<HTMLElement>('[data-mobile-menu]');
		const backdrop = header.querySelector<HTMLElement>('[data-mobile-backdrop]');
		const wrapper = header.querySelector<HTMLElement>('[data-mobile-menu-wrapper]');
		const iconOpen = header.querySelector<SVGElement>('[data-menu-icon-open]');
		const iconClose = header.querySelector<SVGElement>('[data-menu-icon-close]');

		if (!toggle || !menu || !backdrop || !wrapper) return;

		let isOpen = false;
		let closeTimer: ReturnType<typeof setTimeout> | undefined;

		function setMenuOpen(open: boolean) {
			if (open === isOpen) return;
			isOpen = open;

			window.clearTimeout(closeTimer);

			toggle.setAttribute('aria-expanded', String(open));
			toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
			iconOpen?.classList.toggle('hidden', open);
			iconClose?.classList.toggle('hidden', !open);
			document.body.classList.toggle('overflow-hidden', open);

			if (open) {
				backdrop.classList.remove('hidden');
				wrapper.classList.remove('hidden');
				requestAnimationFrame(() => {
					backdrop.classList.add('is-open');
					wrapper.classList.add('is-open');
					wrapper.classList.remove('pointer-events-none');
				});
				return;
			}

			backdrop.classList.remove('is-open');
			wrapper.classList.remove('is-open');
			wrapper.classList.add('pointer-events-none');

			closeTimer = window.setTimeout(() => {
				if (!isOpen) {
					backdrop.classList.add('hidden');
					wrapper.classList.add('hidden');
				}
			}, MENU_TRANSITION_MS);
		}

		toggle.addEventListener('click', () => setMenuOpen(!isOpen));

		backdrop.addEventListener('click', () => setMenuOpen(false));

		menu.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => setMenuOpen(false));
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && isOpen) setMenuOpen(false);
		});
	}

	document.querySelectorAll<HTMLElement>('[data-site-header]').forEach(initSiteHeader);
</script>
