---
import SectionHeaderFrame from './SectionHeaderFrame.astro';
import PackageImageCarousel from './PackageImageCarousel.astro';
import { flightFares } from '../data/flight-fares';
---

<section
	id="flights-section"
	class="section-block section-block--divider px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-12"
	aria-labelledby="flights-heading"
>
	<div class="mx-auto max-w-7xl" data-motion-root data-motion-trigger="inview">
		<SectionHeaderFrame
			eyebrow="Flights"
			heading="Smart fares with dependable route planning"
			headingId="flights-heading"
		>
			<div slot="actions" class="flex items-center gap-3">
				<a
					href="/flights"
					class="inline-flex items-center rounded-full border border-white/20 bg-white/[0.04] px-5 py-2.5 font-sans text-sm font-semibold text-ink-50 backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-gold-500/50 hover:bg-gold-500/10 hover:text-gold-300 active:translate-y-0"
				>
					View all fares
				</a>
			</div>
		</SectionHeaderFrame>

		<div class="mt-6 grid gap-4 md:grid-cols-2">
			{
				flightFares.map((fare, i) => (
					<article
						class="rounded-3xl border border-white/10 bg-white/[0.045] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm"
						data-motion-item="up"
						data-motion-delay={String(i * 90)}
					>
						<p class="font-sans text-xs font-semibold uppercase tracking-[0.12em] text-gold-300">{fare.type}</p>
						<h3 class="mt-2 font-display text-3xl leading-tight text-ink-50">{fare.route}</h3>
						<p class="mt-4 font-display text-4xl leading-none text-gold-200">£{fare.priceFromGbp}</p>
						<div class="mt-4">
							<PackageImageCarousel id={`flight-home-${fare.id}`} title={fare.route} images={fare.images} />
						</div>
						<p class="mt-3 text-sm leading-relaxed text-ink-300">{fare.note}</p>
						<a href="/contact-us" class="mt-5 inline-flex h-10 items-center justify-center rounded-full border border-gold-400/45 bg-gold-500/95 px-4 font-sans text-sm font-semibold text-ink-900 transition-colors hover:bg-gold-400">Request this fare</a>
					</article>
				))
			}
		</div>
	</div>
</section>
