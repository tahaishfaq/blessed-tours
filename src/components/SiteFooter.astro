---
import Logo from './Logo.astro';
import {
	footerCompanyLinks,
	footerContact,
	footerLegalLinks,
	footerPackageLinks,
	footerSocialLinks,
	footerTagline,
} from '../data/footer';
import { phone, whatsapp } from '../data/navigation';

const pathname = Astro.url.pathname;
const year = new Date().getFullYear();
const paymentMethods = [
	{ label: 'Visa', src: '/payments-icons/visa.svg' },
	{ label: 'Mastercard', src: '/payments-icons/mastercard.svg' },
	{ label: 'American Express', src: '/payments-icons/american-express.svg' },
	{ label: 'PayPal', src: '/payments-icons/paypal.svg' },
	{ label: 'Discover', src: '/payments-icons/discover.svg' },
];
const trustIcons = [
	{ label: 'IATA', src: '/images/icons/iata-seeklogo.png' },
	{ label: 'ATOL Protected', src: '/images/icons/atol-protected-seeklogo.png' },
	{ label: 'Ministry of Hajj', src: '/images/icons/ministry%20of%20hajj.png' },
];

function isActive(href: string) {
	if (href === '/') return pathname === '/';
	return pathname.startsWith(href);
}
---

<footer class="site-footer relative border-t border-white/[0.06] bg-ink-950 text-ink-50">
	<div
		class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_100%,rgba(212,165,116,0.08),transparent_65%)]"
		aria-hidden="true"
	></div>

	<div class="relative px-4 pt-4 pb-5 sm:px-6 sm:pt-5 sm:pb-6 lg:px-8 lg:pt-6 lg:pb-8">
		<div class="mx-auto max-w-7xl rounded-3xl border border-gold-500/20 bg-white/[0.025] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] backdrop-blur-sm sm:p-6 lg:p-8">
		<div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-12 lg:gap-8 xl:gap-10">
			<div class="sm:col-span-2 lg:col-span-5">
				<Logo class="mb-5" />
				<p class="max-w-sm font-sans text-sm leading-relaxed text-ink-400">
					{footerTagline}
				</p>
				<div class="mt-6 flex flex-wrap gap-3">
					<a
						href={whatsapp.href}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 rounded-full border border-[#25D366]/35 bg-[#25D366]/10 px-4 py-2.5 font-sans text-sm font-semibold text-[#5dde7a] transition-[background-color,border-color,transform] duration-300 hover:border-[#25D366]/55 hover:bg-[#25D366]/16 active:scale-[0.98]"
					>
						<svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path
								d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
							></path>
						</svg>
						{whatsapp.label}
					</a>
					<a
						href={phone.href}
						class="inline-flex items-center gap-2 rounded-full border border-white/12 bg-white/[0.04] px-4 py-2.5 font-sans text-sm font-semibold text-ink-50 transition-[border-color,background-color,transform] duration-300 hover:border-white/20 hover:bg-white/[0.07] active:scale-[0.98]"
					>
						<svg
							class="size-4 shrink-0 text-gold-400"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							aria-hidden="true"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
							></path>
						</svg>
						{phone.label}
					</a>
				</div>
				<div class="mt-6">
					<p class="font-sans text-xs font-semibold uppercase tracking-[0.14em] text-gold-400">
						Follow us
					</p>
					<div class="mt-3 flex flex-wrap gap-2.5">
						{
							footerSocialLinks.map((link) => (
								<a
									href={link.href}
									target="_blank"
									rel="noopener noreferrer"
									aria-label={link.label}
									class="inline-flex size-10 items-center justify-center rounded-full border border-white/12 bg-white/[0.04] text-ink-300 transition-all duration-300 hover:-translate-y-0.5 hover:border-gold-500/45 hover:bg-gold-500/10 hover:text-gold-300 active:translate-y-0"
								>
									{link.icon === 'tiktok' && (
										<svg class="size-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
											<path d="M16.6 5.82a5.95 5.95 0 003.57 1.21V10a8.86 8.86 0 01-3.55-.75v5.61A6.14 6.14 0 1110.5 8.72c.37 0 .74.03 1.1.1v3.05a3.11 3.11 0 00-1.1-.2 3.16 3.16 0 103.15 3.16V2h2.95v3.82z" />
										</svg>
									)}
									{link.icon === 'instagram' && (
										<svg class="size-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
											<rect x="4" y="4" width="16" height="16" rx="4.5" />
											<circle cx="12" cy="12" r="3.6" />
											<path stroke-linecap="round" d="M17.3 6.9h.01" />
										</svg>
									)}
									{link.icon === 'facebook' && (
										<svg class="size-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
											<path d="M14.2 8.15V6.9c0-.62.42-.77.72-.77h1.83V3.18L14.23 3.17c-2.8 0-3.44 2.1-3.44 3.44v1.54H9.17v3.03h1.62V21h3.41v-9.82h2.3l.31-3.03H14.2z" />
										</svg>
									)}
									{link.icon === 'linkedin' && (
										<svg class="size-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
											<path d="M6.94 8.9H3.8V20h3.14V8.9zM5.37 4a1.82 1.82 0 100 3.64A1.82 1.82 0 005.37 4zm6.54 4.9H8.9V20h3.01v-5.82c0-1.53.29-3.02 2.19-3.02 1.87 0 1.9 1.75 1.9 3.12V20h3.01v-6.45c0-3.17-.68-5.6-4.38-5.6-1.78 0-2.97.98-3.46 1.9h-.04V8.9z" />
										</svg>
									)}
								</a>
							))
						}
					</div>
				</div>
			</div>

			<nav class="lg:col-span-2" aria-label="Packages">
				<h2 class="font-display text-base text-ink-50">Packages</h2>
				<ul class="mt-4 flex flex-wrap gap-2">
					{
						footerPackageLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class:list={[
										'footer-link inline-flex rounded-full border border-white/10 bg-white/[0.035] px-3.5 py-2 font-sans text-sm text-ink-400 transition-[border-color,background-color,color,transform] duration-300 hover:-translate-y-0.5 hover:border-gold-500/35 hover:bg-gold-500/10 hover:text-gold-300 active:translate-y-0',
										isActive(link.href) && 'border-gold-500/35 bg-gold-500/10 text-gold-300',
									]}
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<nav class="lg:col-span-2" aria-label="Company">
				<h2 class="font-display text-base text-ink-50">Company</h2>
				<ul class="mt-4 flex flex-wrap gap-2">
					{
						footerCompanyLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class:list={[
										'footer-link inline-flex rounded-full border border-white/10 bg-white/[0.035] px-3.5 py-2 font-sans text-sm text-ink-400 transition-[border-color,background-color,color,transform] duration-300 hover:-translate-y-0.5 hover:border-gold-500/35 hover:bg-gold-500/10 hover:text-gold-300 active:translate-y-0',
										isActive(link.href) && 'border-gold-500/35 bg-gold-500/10 text-gold-300',
									]}
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<div class="lg:col-span-3">
				<h2 class="font-display text-base text-ink-50">Contact</h2>
				<ul class="mt-4 flex flex-col gap-2">
					<li>
						<a
							href={phone.href}
							class="group inline-flex w-fit items-start gap-3 rounded-full border border-white/10 bg-white/[0.035] px-3.5 py-2 font-sans text-sm text-ink-400 transition-[border-color,background-color,color,transform] hover:-translate-y-0.5 hover:border-gold-500/35 hover:bg-gold-500/10 hover:text-ink-50 active:translate-y-0"
						>
							<svg
								class="mt-0.5 size-4 shrink-0 text-gold-400"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.75"
								aria-hidden="true"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
								></path>
							</svg>
							<span>{phone.label}</span>
						</a>
					</li>
					<li>
						<a
							href={footerContact.email.href}
							class="group inline-flex w-fit items-start gap-3 rounded-full border border-white/10 bg-white/[0.035] px-3.5 py-2 font-sans text-sm text-ink-400 transition-[border-color,background-color,color,transform] hover:-translate-y-0.5 hover:border-gold-500/35 hover:bg-gold-500/10 hover:text-ink-50 active:translate-y-0"
						>
							<svg
								class="mt-0.5 size-4 shrink-0 text-gold-400"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.75"
								aria-hidden="true"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
								></path>
							</svg>
							<span>{footerContact.email.label}</span>
						</a>
					</li>
					<li>
						<a
							href={footerContact.address.href}
							target="_blank"
							rel="noopener noreferrer"
							class="group inline-flex w-fit items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.035] px-3.5 py-2 font-sans text-sm leading-relaxed text-ink-400 transition-[border-color,background-color,color,transform] hover:-translate-y-0.5 hover:border-gold-500/35 hover:bg-gold-500/10 hover:text-ink-50 active:translate-y-0"
						>
						<svg
							class="mt-0.5 size-4 shrink-0 text-gold-400"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							aria-hidden="true"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
							></path>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
							></path>
						</svg>
						<span>{footerContact.address.label}</span>
						</a>
					</li>
				</ul>

				<div class="mt-5">
					<p class="font-sans text-xs font-semibold uppercase tracking-[0.14em] text-gold-400">
						Payment via:
					</p>
					<div class="mt-3 flex max-w-xs flex-wrap gap-2">
						{
							paymentMethods.map((method) => (
								<span class="grid h-8 min-w-14 place-items-center rounded-xl border border-white/20 bg-ink-900 px-2 shadow-[inset_0_1px_0_rgba(255,255,255,0.18)] transition-transform duration-300 hover:scale-[1.03]">
									<img
										src={method.src}
										alt={`${method.label} payment logo`}
										class="max-h-3.5 max-w-[4.5rem] object-contain"
										loading="lazy"
										decoding="async"
									/>
								</span>
							))
						}
					</div>
				</div>
			</div>
		</div>

		<div class="mt-10 border-t border-gold-500/15 pt-7 text-center">
			<p class="font-sans text-xs font-semibold uppercase tracking-[0.14em] text-gold-400">
				Accreditations & partners
			</p>
			<div class="mt-5 flex flex-wrap items-center justify-center gap-3 sm:gap-4" aria-label="Travel accreditations">
				{
					trustIcons.map((icon) => (
						<span class="grid h-16 min-w-[6.75rem] place-items-center rounded-2xl border border-white/25 bg-ink-900 px-2.5 py-2 shadow-[inset_0_1px_0_rgba(255,255,255,0.2)] transition-transform duration-300 hover:scale-[1.03] sm:h-[4.75rem] sm:min-w-32 sm:px-3 md:h-20 md:min-w-36">
							<img
								src={icon.src}
								alt={`${icon.label} logo`}
								class="h-11 w-auto max-w-[7.25rem] object-contain sm:h-[3.25rem] sm:max-w-[8.75rem] md:h-14 md:max-w-[10.5rem]"
								loading="lazy"
								decoding="async"
							/>
						</span>
					))
				}
			</div>
		</div>

		<div
			class="mt-10 flex flex-col gap-4 border-t border-gold-500/15 pt-6 sm:flex-row sm:items-center sm:justify-between"
		>
			<p class="font-sans text-sm text-ink-500">
				&copy; {year} Blessed Tours. All rights reserved.
			</p>
			<nav aria-label="Legal">
				<ul class="flex flex-wrap gap-2">
					{
						footerLegalLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class:list={[
										'inline-flex rounded-full border border-white/10 bg-white/[0.03] px-3.5 py-2 font-sans text-sm text-ink-500 transition-[border-color,background-color,color] duration-300 hover:border-gold-500/30 hover:bg-gold-500/10 hover:text-gold-300',
										isActive(link.href) && 'border-gold-500/35 bg-gold-500/10 text-gold-300',
									]}
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</div>
		</div>
	</div>
</footer>
