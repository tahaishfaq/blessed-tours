---
import {
	newsletterBadge,
	newsletterDescription,
	newsletterHeading,
	newsletterImages,
	newsletterPlaceholder,
	newsletterSubmitLabel,
} from '../data/newsletter';

---

<section
	class="section-block px-4 pt-5 pb-10 sm:px-6 sm:pt-6 sm:pb-12 lg:px-8 lg:pt-7 lg:pb-16"
	aria-labelledby="newsletter-heading"
>
	<div class="relative mx-auto max-w-7xl" data-motion-root data-motion-trigger="inview">
		<div
			class="newsletter-panel relative overflow-hidden rounded-[1.75rem] border border-gold-500/20 bg-white/[0.04] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.08),0_24px_60px_-28px_rgba(0,0,0,0.55)] backdrop-blur-sm sm:rounded-[2rem] sm:p-8 lg:grid lg:grid-cols-2 lg:items-stretch lg:gap-10 lg:p-10 xl:gap-14 xl:p-12"
			data-motion-item="scale"
			data-motion-delay="0"
		>
			<div
				class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_70%_60%_at_0%_50%,rgba(212,165,116,0.1),transparent_55%)]"
				aria-hidden="true"
			></div>

			<div class="relative z-[1] flex flex-col justify-center lg:max-w-xl">
				<span
					class="mb-4 inline-flex w-fit self-start rounded-full border border-white/12 bg-white/[0.05] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-wider text-gold-400 backdrop-blur-sm"
					data-motion-item="up"
					data-motion-delay="75"
				>
					{newsletterBadge}
				</span>
				<h2
					id="newsletter-heading"
					class="font-display text-3xl leading-[1.1] tracking-tight text-ink-50 sm:text-4xl lg:text-[2.5rem]"
					data-motion-item="up"
					data-motion-delay="150"
				>
					{newsletterHeading}
				</h2>
				<p
					class="mt-4 font-sans text-base leading-relaxed text-ink-400"
					data-motion-item="up"
					data-motion-delay="225"
				>
					{newsletterDescription}
				</p>

				<form
					class="newsletter-form mt-8 w-full max-w-md"
					action="#"
					method="post"
					data-newsletter-form
					data-motion-item="up"
					data-motion-delay="300"
					novalidate
				>
					<div class="newsletter-form__bar flex flex-col gap-2.5 sm:flex-row sm:items-center sm:gap-1.5">
						<label class="sr-only" for="newsletter-email">Email address</label>
						<input
							id="newsletter-email"
							type="email"
							name="email"
							required
							autocomplete="email"
							placeholder={newsletterPlaceholder}
							class="newsletter-form__input h-12 w-full min-w-0 rounded-full border border-white/12 bg-white/[0.05] px-5 font-sans text-sm text-ink-50 shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] outline-none transition-[border-color,background-color] duration-300 placeholder:text-ink-500 sm:h-11 sm:flex-1 sm:border-0 sm:bg-transparent sm:px-4 sm:shadow-none"
						/>
						<button
							type="submit"
							class="newsletter-form__submit inline-flex h-12 w-full shrink-0 items-center justify-center gap-2 rounded-full border border-gold-500/35 bg-gold-500/12 py-1.5 pr-1.5 pl-5 font-sans text-sm font-semibold text-gold-400 transition-[background-color,border-color,transform] duration-300 hover:border-gold-500/50 hover:bg-gold-500/20 active:scale-[0.98] sm:h-11 sm:w-auto"
						>
							<span>{newsletterSubmitLabel}</span>
							<span
								class="inline-flex size-9 items-center justify-center rounded-full bg-gold-500 text-ink-950"
								aria-hidden="true"
							>
								<svg
									class="size-4"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2.25"
								>
									<path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"
									></path>
								</svg>
							</span>
						</button>
					</div>
				</form>
				<p
					class="newsletter-form__success mt-3 hidden font-sans text-sm text-gold-400"
					data-newsletter-success
					role="status"
				>
					Thank you — you are on the list. We will be in touch soon.
				</p>
			</div>

			<div
				class="newsletter-collage relative z-[1] mt-8 h-[17.5rem] sm:h-[19rem] lg:mt-0 lg:h-full lg:min-h-[22rem] lg:max-h-[26rem]"
				data-motion-item="up"
				data-motion-delay="175"
			>
				<div class="newsletter-collage__main">
					<img
						src={newsletterImages.main.src}
						alt={newsletterImages.main.alt}
						width="480"
						height="640"
						loading="lazy"
						decoding="async"
					/>
				</div>
				<div class="newsletter-collage__top">
					<img
						src={newsletterImages.top.src}
						alt={newsletterImages.top.alt}
						width="400"
						height="300"
						loading="lazy"
						decoding="async"
					/>
				</div>
				<div class="newsletter-collage__bottom">
					<img
						src={newsletterImages.bottom.src}
						alt={newsletterImages.bottom.alt}
						width="400"
						height="300"
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	function initNewsletterForm() {
		const form = document.querySelector<HTMLFormElement>('[data-newsletter-form]');
		if (!form || form.dataset.newsletterReady === 'true') return;

		const success = document.querySelector<HTMLElement>('[data-newsletter-success]');

		form.addEventListener('submit', (event) => {
			event.preventDefault();
			const email = form.querySelector<HTMLInputElement>('input[type="email"]');
			if (!email?.value || !email.checkValidity()) {
				email?.focus();
				return;
			}

			form.reset();
			success?.classList.remove('hidden');
		});

		form.dataset.newsletterReady = 'true';
	}

	initNewsletterForm();
	document.addEventListener('astro:page-load', initNewsletterForm);
</script>

<style>
	.newsletter-collage {
		display: grid;
		grid-template-columns: minmax(0, 1.06fr) minmax(0, 1fr);
		grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
		gap: 0.625rem;
	}

	.newsletter-collage__main {
		grid-row: 1 / -1;
		position: relative;
		min-height: 0;
		overflow: hidden;
		border-radius: 1rem;
		border: 1px solid hsl(0 0% 100% / 0.1);
	}

	.newsletter-collage__top,
	.newsletter-collage__bottom {
		position: relative;
		min-height: 0;
		overflow: hidden;
		border-radius: 1rem;
		border: 1px solid hsl(0 0% 100% / 0.1);
	}

	.newsletter-collage img {
		position: absolute;
		inset: 0;
		height: 100%;
		width: 100%;
		object-fit: cover;
		object-position: center;
	}

	@media (min-width: 640px) {
		.newsletter-form__bar {
			border-radius: 9999px;
			border: 1px solid hsl(0 0% 100% / 0.12);
			background: hsl(0 0% 100% / 0.04);
			padding: 0.375rem;
			box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.06);
			transition:
				border-color 0.3s ease,
				box-shadow 0.3s ease;
		}

		.newsletter-form__bar:focus-within {
			border-color: hsl(36 75% 65% / 0.35);
			box-shadow:
				inset 0 1px 0 hsl(0 0% 100% / 0.08),
				0 0 0 2px hsl(36 75% 65% / 0.12);
		}

		.newsletter-form__input:focus {
			outline: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.newsletter-form__submit {
			transition: none;
		}

		.newsletter-form__bar {
			transition: none;
		}
	}
</style>
