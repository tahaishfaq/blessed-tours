---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';

const paymentMethods = [
	'Online money transfer',
	'Payment via cash',
	'Debit cards',
	'Credit cards',
	'Payment cards',
	'Cheque payment',
];

const securitySections = [
	{
		id: 'secure-payment-methods',
		title: 'Secure Payment Methods',
		body: 'Blessed Tours UK facilitates safe payment options for flights, hotels, Umrah packages, transport, visas, and insurance through secure payment methods, including 3D secure payment links where applicable.',
	},
	{
		id: 'payment-choice',
		title: 'Payment Choice',
		body: 'You may choose the payment method that is convenient for you and complete your payment through that method. Our team can guide you on the most suitable option for your booking.',
	},
	{
		id: 'cheque-payments',
		title: 'Cheque Payments',
		body: 'Cheque payment is not preferred because it can take more than 10 days to clear. If you wish to pay by cheque, please speak with us before making arrangements.',
	},
	{
		id: 'safe-booking',
		title: 'Safe Booking Support',
		body: 'With safe payment handling, your holiday package, pilgrimage package, or travel service can be booked with greater confidence and fewer payment-related concerns.',
	},
];
---

<Layout
	title="Payment Security — Blessed Tours"
	description="Learn how Blessed Tours UK supports secure payments for flights, hotels, Umrah packages, transport, visas, insurance, and holiday bookings."
>
	<main class="landing-page">
		<SiteHeader />

		<section class="section-block px-4 pt-16 pb-8 sm:px-6 sm:pt-20 sm:pb-14 lg:px-8 lg:pt-24">
			<div class="mx-auto max-w-7xl" data-motion-root data-motion-trigger="load">
				<div class="grid gap-8 lg:grid-cols-[0.72fr_0.28fr] lg:items-end">
					<div class="max-w-3xl">
						<p
							class="mb-4 inline-flex rounded-full border border-white/15 bg-white/[0.06] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-wider text-gold-400 backdrop-blur-sm"
							data-motion-item="up"
							data-motion-delay="0"
						>
							Secure payments
						</p>
						<h1
							class="font-display text-[2.5rem] leading-[0.98] tracking-tight text-ink-50 sm:text-5xl lg:text-[4rem]"
							data-motion-item="up"
							data-motion-delay="75"
						>
							Payment Security
						</h1>
						<p
							class="mt-5 max-w-2xl font-sans text-base leading-relaxed text-ink-300 sm:text-lg"
							data-motion-item="up"
							data-motion-delay="150"
						>
							In order to keep your payments safe against the flights, hotels, Umrah packages,
							transport, visa, and insurance that you buy, Blessed Tours UK facilitates safe
							payment methods including secure 3D payment links.
						</p>
					</div>

					<div
						class="rounded-3xl border border-white/10 bg-white/[0.05] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] backdrop-blur-sm"
						data-motion-item="up"
						data-motion-delay="225"
					>
						<p class="font-sans text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-gold-400">
							Applies to
						</p>
						<p class="mt-2 font-display text-2xl leading-tight text-ink-50">
							Travel bookings & packages
						</p>
						<p class="mt-3 font-sans text-sm leading-relaxed text-ink-400">
							Payment guidance for flights, hotels, Umrah packages, transport, visas, insurance,
							and holiday services.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="section-block section-block--divider px-4 py-8 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
			<div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[18rem_1fr] lg:gap-10">
				<aside class="min-w-0 lg:sticky lg:top-28 lg:self-start" aria-label="Payment security sections">
					<div
						class="min-w-0 rounded-3xl border border-white/10 bg-white/[0.04] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] backdrop-blur-sm sm:p-4"
						data-motion-root
						data-motion-trigger="inview"
					>
						<p
							class="px-2 font-sans text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-gold-400"
							data-motion-item="up"
							data-motion-delay="0"
						>
							On this page
						</p>
						<nav class="-mx-1 mt-3 flex min-w-0 gap-2 overflow-x-auto px-1 pb-1 lg:mx-0 lg:grid lg:gap-1 lg:overflow-visible lg:px-0 lg:pb-0">
							<a
								href="#payment-methods"
								class="max-w-[78vw] shrink-0 truncate rounded-full border border-white/10 bg-white/[0.03] px-3 py-2 font-sans text-sm text-ink-300 transition-colors duration-300 hover:bg-white/[0.06] hover:text-gold-300 lg:max-w-none lg:rounded-xl lg:border-0 lg:bg-transparent lg:px-2.5"
								data-motion-item="up"
								data-motion-delay="75"
							>
								Payment Methods
							</a>
							{
								securitySections.map((section, index) => (
									<a
										href={`#${section.id}`}
										class="max-w-[78vw] shrink-0 truncate rounded-full border border-white/10 bg-white/[0.03] px-3 py-2 font-sans text-sm text-ink-300 transition-colors duration-300 hover:bg-white/[0.06] hover:text-gold-300 lg:max-w-none lg:rounded-xl lg:border-0 lg:bg-transparent lg:px-2.5"
										data-motion-item="up"
										data-motion-delay={String(125 + index * 35)}
									>
										{section.title}
									</a>
								))
							}
						</nav>
					</div>
				</aside>

				<div class="min-w-0 max-w-full overflow-hidden" data-motion-root data-motion-trigger="inview">
					<article
						id="payment-methods"
						class="min-w-0 max-w-full scroll-mt-28 overflow-hidden rounded-3xl border border-white/10 bg-white/[0.045] p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm sm:p-6"
						data-motion-item="up"
						data-motion-delay="0"
					>
						<p class="font-sans text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-gold-400">
							Methods we allow
						</p>
						<h2 class="mt-2 font-display text-2xl leading-tight text-ink-50">
							Available Payment Methods
						</h2>
						<div class="mt-5 grid gap-3 sm:grid-cols-2">
							{
								paymentMethods.map((method, index) => (
									<div class="flex min-w-0 items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.045] p-3">
										<span class="inline-flex size-9 shrink-0 items-center justify-center rounded-xl border border-gold-500/25 bg-gold-500/10 font-sans text-xs font-bold text-gold-300">
											{String(index + 1).padStart(2, '0')}
										</span>
										<span class="min-w-0 break-words font-sans text-sm font-semibold text-ink-100">{method}</span>
									</div>
								))
							}
						</div>
					</article>

					<div class="mt-4 grid gap-4">
						{
							securitySections.map((section, index) => (
								<article
									id={section.id}
									class="min-w-0 max-w-full scroll-mt-28 overflow-hidden rounded-3xl border border-white/10 bg-white/[0.045] p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm transition-colors duration-300 hover:border-gold-500/25 hover:bg-white/[0.06] sm:p-6"
									data-motion-item="up"
									data-motion-delay={String(100 + index * 45)}
								>
									<div class="grid gap-4 sm:grid-cols-[3rem_1fr] sm:gap-5">
										<span class="inline-flex size-11 items-center justify-center rounded-2xl border border-gold-500/25 bg-gold-500/10 font-sans text-sm font-bold text-gold-300">
											{String(index + 1).padStart(2, '0')}
										</span>
										<div class="min-w-0 max-w-full">
											<h2 class="break-words font-display text-xl leading-tight text-ink-50 sm:text-2xl">
												{section.title}
											</h2>
											<p class="mt-3 max-w-full break-words font-sans text-[0.9375rem] leading-relaxed text-ink-300 sm:text-base">
												{section.body}
											</p>
										</div>
									</div>
								</article>
							))
						}
					</div>

					<div
						class="mt-6 overflow-hidden rounded-3xl border border-gold-500/25 bg-gold-500/10 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] sm:p-7"
						data-motion-item="up"
						data-motion-delay="325"
					>
						<p class="font-display text-2xl leading-tight text-ink-50">Need payment help?</p>
						<p class="mt-3 max-w-2xl font-sans text-base leading-relaxed text-ink-300">
							You may choose the payment method that is convenient for you. If you are unsure
							which option is best for your booking, please contact us before making payment.
						</p>
						<div class="mt-5 flex flex-col gap-3 sm:flex-row">
							<a
								href="tel:02037731172"
								class="inline-flex w-full items-center justify-center rounded-full border border-gold-500/35 bg-gold-500/15 px-5 py-2.5 font-sans text-sm font-semibold text-gold-300 transition-all duration-300 hover:-translate-y-0.5 hover:bg-gold-500/22 active:translate-y-0 sm:w-auto"
							>
								Call 0203-773-1172
							</a>
							<a
								href="mailto:info@blessedtours.co.uk"
								class="inline-flex w-full items-center justify-center rounded-full border border-white/15 bg-white/[0.05] px-5 py-2.5 font-sans text-sm font-semibold text-ink-50 transition-all duration-300 hover:-translate-y-0.5 hover:border-gold-500/35 hover:text-gold-300 active:translate-y-0 sm:w-auto"
							>
								Email us
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
