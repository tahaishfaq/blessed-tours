---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { phone, whatsapp } from '../data/navigation';

const holidayTypes = [
	{
		title: 'Family Holidays',
		description:
			'Comfortable hotel, flight, and transfer options for families who want a smooth break with practical support.',
	},
	{
		title: 'Islamic Tours',
		description:
			'Meaningful travel plans shaped around heritage, worship, food preferences, and family-friendly pacing.',
	},
	{
		title: 'City Breaks',
		description:
			'Short stays with flights, central hotels, and flexible dates for couples, friends, or small groups.',
	},
];

const inclusions = [
	'Flight options from major UK airports',
	'Hotel recommendations matched to your budget',
	'Airport transfers and local transport guidance',
	'Family, couple, and group travel planning',
	'Optional tours, activities, and itinerary support',
	'Clear payment guidance before booking',
];

const destinations = [
	{ name: 'Dubai', note: 'Family stays, shopping, beaches, and premium hotels' },
	{ name: 'Istanbul', note: 'Islamic heritage, food, culture, and short breaks' },
	{ name: 'Malaysia', note: 'Halal-friendly resorts, nature, and city stays' },
	{ name: 'Morocco', note: 'Historic cities, riads, and guided family tours' },
];
---

<Layout
	title="Holiday Packages — Blessed Tours"
	description="Plan halal-friendly holiday packages with Blessed Tours, including flights, hotels, transfers, family breaks, Islamic tours, and city stays."
>
	<main class="landing-page">
		<SiteHeader />

		<section class="section-block px-4 pt-16 pb-10 sm:px-6 sm:pt-20 sm:pb-16 lg:px-8 lg:pt-24 lg:pb-20">
			<div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.58fr_0.42fr] lg:items-stretch" data-motion-root data-motion-trigger="load">
				<div class="flex min-w-0 flex-col justify-center">
					<p
						class="mb-4 inline-flex w-fit rounded-full border border-white/15 bg-white/[0.06] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-wider text-gold-400 backdrop-blur-sm"
						data-motion-item="up"
					>
						Holiday Packages
					</p>
					<h1
						class="max-w-4xl font-display text-[2.5rem] leading-[0.98] tracking-tight text-ink-50 sm:text-5xl lg:text-[4.5rem]"
						data-motion-item="up"
						data-motion-delay="75"
					>
						Tailored holidays planned around comfort, family, and faith.
					</h1>
					<p
						class="mt-5 max-w-2xl font-sans text-base leading-relaxed text-ink-300 sm:text-lg"
						data-motion-item="up"
						data-motion-delay="150"
					>
						Our holiday packages are prepared for travellers who want trusted arrangements,
						clear pricing, and practical support from a UK-based team. Share your dates and
						preferences, and we will help shape the right flight, hotel, and transfer options.
					</p>
					<div class="mt-6 flex flex-col gap-3 sm:flex-row" data-motion-item="up" data-motion-delay="225">
						<a
							href={whatsapp.href}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex h-12 w-full items-center justify-center rounded-full border border-[#25D366]/35 bg-[#25D366]/10 px-6 font-sans text-sm font-semibold text-[#5dde7a] transition-colors hover:bg-[#25D366]/16 sm:w-auto"
						>
							Message on WhatsApp
						</a>
						<a
							href="/contact-us"
							class="inline-flex h-12 w-full items-center justify-center rounded-full border border-gold-400/50 bg-gold-500/95 px-6 font-sans text-sm font-bold text-ink-900 transition-colors hover:bg-gold-400 sm:w-auto"
						>
							Request a Holiday Quote
						</a>
					</div>
				</div>

				<div
					class="relative min-h-[18rem] overflow-hidden rounded-[1.5rem] border border-white/10 bg-ink-950 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] sm:min-h-[24rem] sm:rounded-[2rem] lg:min-h-[28rem]"
					data-motion-item="scale"
					data-motion-delay="175"
				>
					<img
						src="/images/service-images/for-holiday.jpg"
						alt="Holiday travel planning with scenic destination"
						class="absolute inset-0 h-full w-full object-cover opacity-75"
						loading="eager"
						decoding="async"
						width="1100"
						height="900"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/35 to-transparent"></div>
					<div class="absolute right-3 bottom-3 left-3 rounded-3xl border border-white/12 bg-ink-950/72 p-4 backdrop-blur-md sm:right-5 sm:bottom-5 sm:left-5 sm:p-5">
						<p class="font-sans text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-gold-400">
							Plan with confidence
						</p>
						<p class="mt-2 font-display text-xl leading-tight text-ink-50 sm:text-2xl">
							Flights, hotels, transfers, and support arranged in one place.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="section-block section-block--divider px-4 py-8 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
			<div class="mx-auto max-w-7xl" data-motion-root data-motion-trigger="inview">
				<div class="max-w-3xl" data-motion-item="up">
					<p class="mb-4 inline-flex rounded-full border border-white/15 bg-white/[0.06] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-wider text-gold-400 backdrop-blur-sm">
						Travel styles
					</p>
					<h2 class="font-display text-3xl leading-tight tracking-tight text-ink-50 sm:text-4xl lg:text-[2.75rem]">
						Choose the kind of holiday you want to build.
					</h2>
				</div>

				<div class="mt-7 grid gap-4 md:grid-cols-3">
					{
						holidayTypes.map((item, index) => (
							<article
								class="min-w-0 rounded-3xl border border-white/10 bg-white/[0.045] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm sm:p-6"
								data-motion-item="up"
								data-motion-delay={String(100 + index * 80)}
							>
								<span class="inline-flex size-11 items-center justify-center rounded-2xl border border-gold-500/25 bg-gold-500/10 font-sans text-sm font-bold text-gold-300">
									{String(index + 1).padStart(2, '0')}
								</span>
								<h3 class="mt-5 break-words font-display text-2xl leading-tight text-ink-50">
									{item.title}
								</h3>
								<p class="mt-3 break-words font-sans text-[0.9375rem] leading-relaxed text-ink-300">
									{item.description}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section-block section-block--divider px-4 py-8 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
			<div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[0.44fr_0.56fr] lg:gap-8" data-motion-root data-motion-trigger="inview">
				<div class="rounded-[1.5rem] border border-gold-500/25 bg-gold-500/10 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] sm:rounded-[2rem] sm:p-8" data-motion-item="up">
					<p class="font-sans text-xs font-semibold uppercase tracking-[0.14em] text-gold-400">
						What can be included
					</p>
					<h2 class="mt-3 font-display text-2xl leading-tight text-ink-50 sm:text-4xl">
						Package support from enquiry to booking.
					</h2>
					<p class="mt-5 font-sans text-[0.9375rem] leading-relaxed text-ink-300 sm:text-base">
						Every quote is tailored. We can keep things simple with flights and hotel, or build
						a fuller itinerary with transfers, activities, and family-friendly recommendations.
					</p>
				</div>

				<div class="grid gap-3 sm:grid-cols-2" data-motion-item="up" data-motion-delay="100">
					{
						inclusions.map((item) => (
							<div class="flex min-w-0 items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.045] p-4">
								<span class="mt-0.5 inline-flex size-8 shrink-0 items-center justify-center rounded-xl border border-gold-500/25 bg-gold-500/10 text-gold-300">
									<svg class="size-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
										<path d="M4 10.5l3.5 3.5L16 5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
									</svg>
								</span>
								<p class="min-w-0 break-words font-sans text-sm font-semibold leading-relaxed text-ink-100">
									{item}
								</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="section-block section-block--divider px-4 py-8 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
			<div class="mx-auto max-w-7xl" data-motion-root data-motion-trigger="inview">
				<div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
					<div class="max-w-3xl" data-motion-item="up">
						<p class="mb-4 inline-flex rounded-full border border-white/15 bg-white/[0.06] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-wider text-gold-400 backdrop-blur-sm">
							Popular options
						</p>
						<h2 class="font-display text-3xl leading-tight tracking-tight text-ink-50 sm:text-4xl lg:text-[2.75rem]">
							Destinations we can help you plan.
						</h2>
					</div>
					<a
						href={phone.href}
						class="inline-flex h-11 w-full items-center justify-center rounded-full border border-white/15 bg-white/[0.06] px-5 font-sans text-sm font-semibold text-ink-100 transition-colors hover:border-gold-500/45 hover:text-gold-200 sm:w-auto"
						data-motion-item="up"
						data-motion-delay="100"
					>
						Call {phone.label}
					</a>
				</div>

				<div class="mt-7 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
					{
						destinations.map((item, index) => (
							<article
								class="min-w-0 rounded-3xl border border-white/10 bg-white/[0.045] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm"
								data-motion-item="up"
								data-motion-delay={String(150 + index * 70)}
							>
								<h3 class="break-words font-display text-2xl leading-tight text-ink-50">{item.name}</h3>
								<p class="mt-3 break-words font-sans text-sm leading-relaxed text-ink-400">
									{item.note}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</section>
	</main>
</Layout>
