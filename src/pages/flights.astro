---
import Layout from '../layouts/Layout.astro';
import DatePickerField from '../components/DatePickerField.astro';
import SiteHeader from '../components/SiteHeader.astro';
import PackageImageCarousel from '../components/PackageImageCarousel.astro';
import { flightFares } from '../data/flight-fares';

const seoTitle = 'Cheap Flights from UK to Saudi Arabia | Umrah Flights to Jeddah & Madinah';
const seoDescription =
	'Explore affordable flight deals from the UK to Saudi Arabia with Blessed Tours. Compare cheap Umrah flights to Jeddah and Madinah, with flexible dates and trusted support.';
---

<Layout title={seoTitle} description={seoDescription}>
	<main class="landing-page">
		<section
			class="relative isolate min-h-[min(88svh,52rem)] w-full overflow-hidden bg-ink-950 sm:min-h-[40rem] lg:min-h-[min(92svh,56rem)]"
			aria-labelledby="flights-hero-heading"
		>
			<SiteHeader overlay />

			<img
				src="https://images.pexels.com/photos/46148/aircraft-jet-landing-cloud-46148.jpeg?auto=compress&cs=tinysrgb&w=2000"
				alt=""
				class="absolute inset-0 h-full w-full object-cover object-[50%_35%] sm:object-[50%_40%]"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
			<div
				class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/45 to-ink-950/95"
				aria-hidden="true"
			></div>
			<div
				class="absolute inset-0 bg-gradient-to-r from-black/55 via-transparent to-black/35 sm:from-black/65"
				aria-hidden="true"
			></div>

			<div
				class="relative z-10 flex min-h-[min(88svh,52rem)] w-full flex-col justify-between px-4 pt-28 pb-8 sm:min-h-[40rem] sm:px-6 sm:pt-32 sm:pb-10 lg:min-h-[min(92svh,56rem)] lg:px-8 lg:pt-36 lg:pb-12"
				data-motion-root
				data-motion-trigger="load"
			>
				<div class="mx-auto w-full max-w-7xl text-center">
					<p
						class="inline-flex rounded-full border border-white/20 bg-white/[0.08] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-[0.13em] text-gold-300 backdrop-blur-sm"
						data-motion-item="up"
					>
						Flights
					</p>
					<h1
						id="flights-hero-heading"
						class="mx-auto mt-4 max-w-4xl font-display text-4xl leading-[1.05] tracking-tight text-ink-50 sm:text-5xl lg:text-6xl"
						data-motion-item="up"
						data-motion-delay="75"
					>
						Cheap Flights From UK to Saudi Arabia
					</h1>
					<p
						class="mx-auto mt-4 max-w-3xl font-sans text-base leading-relaxed text-ink-100/95 sm:text-xl"
						data-motion-item="up"
						data-motion-delay="150"
					>
						Affordable airfares, trusted routes, and flexible dates for Umrah flights to Jeddah and
						Madinah.
					</p>
				</div>

				<form
					class="mx-auto mt-8 grid w-full max-w-7xl grid-cols-1 gap-3 rounded-3xl border border-white/20 bg-black/35 p-3 shadow-[0_24px_70px_rgba(0,0,0,0.45),inset_0_1px_0_rgba(255,255,255,0.12)] backdrop-blur-xl sm:mt-10 sm:grid-cols-2 sm:p-4 lg:grid-cols-5 lg:p-5"
					data-flights-enquiry-form
					data-motion-item="up"
					data-motion-delay="225"
					novalidate
				>
					<select
						name="trip_type"
						data-trip-type
						class="h-12 rounded-xl border border-white/35 bg-white/92 px-4 font-sans text-base text-ink-900 outline-none transition-all focus:border-gold-500 focus:ring-2 focus:ring-gold-500/25"
					>
						<option value="round-trip">Round-trip</option>
						<option value="one-way">One-way</option>
					</select>
					<input
						type="text"
						placeholder="From"
						class="h-12 rounded-xl border border-white/35 bg-white/92 px-4 font-sans text-base text-ink-900 placeholder:text-ink-500 outline-none transition-all focus:border-gold-500 focus:ring-2 focus:ring-gold-500/25"
					/>
					<input
						type="text"
						placeholder="To"
						class="h-12 rounded-xl border border-white/35 bg-white/92 px-4 font-sans text-base text-ink-900 placeholder:text-ink-500 outline-none transition-all focus:border-gold-500 focus:ring-2 focus:ring-gold-500/25"
					/>
					<DatePickerField
						id="flights-start-date"
						name="start_date"
						label="Start date"
						linksTo="end_date"
						required
					/>
					<DatePickerField
						id="flights-end-date"
						name="end_date"
						label="End date"
						required
					/>
					<input
						type="text"
						placeholder="Travelers"
						class="h-12 rounded-xl border border-white/35 bg-white/92 px-4 font-sans text-base text-ink-900 placeholder:text-ink-500 outline-none transition-all focus:border-gold-500 focus:ring-2 focus:ring-gold-500/25"
					/>
					<select
						class="h-12 rounded-xl border border-white/35 bg-white/92 px-4 font-sans text-base text-ink-900 outline-none transition-all focus:border-gold-500 focus:ring-2 focus:ring-gold-500/25"
					>
						<option>Cabin Class</option>
						<option>Economy</option>
						<option>Premium Economy</option>
						<option>Business</option>
					</select>
					<input
						type="text"
						placeholder="Name*"
						class="h-12 rounded-xl border border-white/35 bg-white/92 px-4 font-sans text-base text-ink-900 placeholder:text-ink-500 outline-none transition-all focus:border-gold-500 focus:ring-2 focus:ring-gold-500/25"
						required
					/>
					<input
						type="tel"
						placeholder="Phone*"
						class="h-12 rounded-xl border border-white/35 bg-white/92 px-4 font-sans text-base text-ink-900 placeholder:text-ink-500 outline-none transition-all focus:border-gold-500 focus:ring-2 focus:ring-gold-500/25"
						required
					/>
					<input
						type="email"
						placeholder="Email"
						class="h-12 rounded-xl border border-white/35 bg-white/92 px-4 font-sans text-base text-ink-900 placeholder:text-ink-500 outline-none transition-all focus:border-gold-500 focus:ring-2 focus:ring-gold-500/25"
					/>
					<button
						type="submit"
						class="inline-flex h-12 items-center justify-center rounded-xl border border-gold-400/55 bg-gold-500 px-6 font-sans text-base font-semibold text-ink-900 transition-all duration-300 hover:bg-gold-400 active:translate-y-px sm:col-span-2 lg:col-span-5"
					>
						Submit Flight Enquiry
					</button>
				</form>
			</div>
		</section>

		<section class="section-block section-block--divider px-4 pb-10 sm:px-6 sm:pb-12 lg:px-8 lg:pb-14">
			<div class="mx-auto max-w-7xl rounded-[1.75rem] border border-white/10 bg-white/[0.04] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] backdrop-blur-sm sm:p-7">
				<h2 class="font-display text-3xl leading-tight text-ink-50">Explore Affordable Flight Deals From the UK</h2>
				<div class="mt-4 space-y-4 text-sm leading-relaxed text-ink-300 sm:text-base">
					<p>At Blessed Tours, we specialise in offering cheap flight deals from the UK to Saudi Arabia, making your journey to Makkah and Madinah more affordable than ever. Whether you are planning to perform Umrah or visit family, we help you find low-cost flights without compromising on comfort or service.</p>
					<p>We offer both one-way and return flights to major airports in Saudi Arabia, including Jeddah and Madinah, with access to trusted airlines and competitive fares. Our team regularly updates flight options to bring you the best seasonal offers, especially during Ramadan, school holidays, and off-peak travel times.</p>
					<p>With flexible travel dates and reliable support, Blessed Tours makes it easy for UK pilgrims to reach the Holy Land at affordable prices so you can focus on your spiritual journey with peace of mind.</p>
				</div>
			</div>
		</section>

		<section class="section-block section-block--divider px-4 pb-10 sm:px-6 sm:pb-12 lg:px-8 lg:pb-14">
			<div class="mx-auto max-w-7xl rounded-[1.75rem] border border-white/10 bg-white/[0.04] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] backdrop-blur-sm sm:p-7">
				<h2 class="font-display text-3xl leading-tight text-ink-50">Tips for Finding the Cheapest Flights</h2>
				<ul class="mt-4 space-y-3 text-sm leading-relaxed text-ink-300 sm:text-base">
					<li><span class="text-gold-300 font-semibold">Book early:</span> Prices usually rise near departure, especially in Ramadan and school holiday periods.</li>
					<li><span class="text-gold-300 font-semibold">Stay flexible with dates:</span> Mid-week and off-peak flight times can reduce fares significantly.</li>
					<li><span class="text-gold-300 font-semibold">Compare nearby airports:</span> Manchester, Birmingham, and Heathrow can produce different pricing windows.</li>
					<li><span class="text-gold-300 font-semibold">Set fare alerts:</span> Stay updated on short-term promotions and seasonal discounts.</li>
					<li><span class="text-gold-300 font-semibold">Travel light where possible:</span> Hand-luggage fares can reduce overall trip cost on selected airlines.</li>
				</ul>
			</div>
		</section>

		<section class="section-block section-block--divider px-4 pb-14 sm:px-6 sm:pb-18 lg:px-8 lg:pb-24">
			<div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-2" data-motion-root data-motion-trigger="inview">
				{
					flightFares.map((fare, i) => (
						<article class="rounded-3xl border border-white/10 bg-white/[0.045] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm" data-motion-item="up" data-motion-delay={String(i * 90)}>
							<div class="flex items-start justify-between gap-4">
								<div>
									<p class="font-sans text-xs font-semibold uppercase tracking-[0.12em] text-gold-300">{fare.type}</p>
									<h2 class="mt-2 font-display text-3xl leading-tight text-ink-50">{fare.route}</h2>
								</div>
								<p class="font-display text-4xl leading-none text-gold-200">£{fare.priceFromGbp}</p>
							</div>
							<div class="mt-4">
								<PackageImageCarousel id={`flight-all-${fare.id}`} title={fare.route} images={fare.images} />
							</div>
							<p class="mt-4 rounded-2xl border border-white/10 bg-black/20 p-4 text-sm leading-relaxed text-ink-300">{fare.note}</p>
							<div class="mt-5 flex flex-wrap gap-2">
								<span class="inline-flex rounded-full border border-white/12 bg-white/[0.04] px-3 py-1 text-xs text-ink-300">Route guidance included</span>
								<span class="inline-flex rounded-full border border-white/12 bg-white/[0.04] px-3 py-1 text-xs text-ink-300">Package coordination support</span>
							</div>
							<a href="/contact-us" class="mt-5 inline-flex h-11 items-center justify-center rounded-full border border-gold-400/50 bg-gold-500/95 px-5 font-sans text-sm font-bold text-ink-900 transition-all hover:bg-gold-400">Request Flight Quote</a>
						</article>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<script>
	function initFlightsTripType(form: HTMLFormElement) {
		if (form.dataset.tripTypeReady === 'true') return;
		form.dataset.tripTypeReady = 'true';

		const tripSelect = form.querySelector<HTMLSelectElement>('[data-trip-type]');
		const endInput = form.querySelector<HTMLInputElement>('input[name="end_date"]');
		if (!tripSelect || !endInput) return;

		const syncEndDate = () => {
			const oneWay = tripSelect.value === 'one-way';
			const fp = (
				endInput as HTMLInputElement & {
					_flatpickr?: {
						clear: () => void;
						set: (key: string, value: unknown) => void;
						altInput?: HTMLInputElement;
					};
				}
			)._flatpickr;

			endInput.toggleAttribute('disabled', oneWay);
			endInput.toggleAttribute('required', !oneWay);

			if (fp) {
				if (oneWay) {
					fp.clear();
					fp.set('clickOpens', false);
					fp.altInput?.setAttribute('disabled', 'true');
				} else {
					fp.set('clickOpens', true);
					fp.altInput?.removeAttribute('disabled');
				}
			}
		};

		tripSelect.addEventListener('change', syncEndDate);
		requestAnimationFrame(syncEndDate);
	}

	function setupFlightsForms() {
		document.querySelectorAll<HTMLFormElement>('[data-flights-enquiry-form]').forEach(initFlightsTripType);
	}

	setupFlightsForms();
	document.addEventListener('astro:page-load', setupFlightsForms);
</script>
