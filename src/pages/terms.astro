---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';

const termsSections = [
	{
		id: 'acceptance-of-terms',
		title: 'Acceptance of Terms',
		body: 'By using this website or booking with us, you accept our Terms & Conditions.',
	},
	{
		id: 'limits-on-use',
		title: 'Limits on Use',
		body: 'You must not use this website or our services for personal profit. You cannot copy, sell, or share our services or information with anyone else.',
	},
	{
		id: 'booking-confirmation',
		title: 'Booking Confirmation',
		body: 'Your booking is confirmed when we get your deposit. We will then send you a confirmation document.',
	},
	{
		id: 'payments-and-pricing',
		title: 'Payments & Pricing',
		body: 'Full payment must be made before departure. Prices can change due to supplier updates or currency changes.',
	},
	{
		id: 'flight-arrangements',
		title: 'Flight Arrangements',
		body: 'You must confirm your flights at least 72 hours before travel. Failure to do so may cause extra charges.',
	},
	{
		id: 'cancellations-by-you',
		title: 'Cancellations by You',
		body: 'All cancellations must be made in writing. Cancellation charges depend on how close it is to your travel date.',
	},
	{
		id: 'cancellations-by-us',
		title: 'Cancellations by Us',
		body: 'If we need to change your trip due to unforeseen events, we’ll offer you a new plan or a refund.',
	},
	{
		id: 'passport-and-visa-requirements',
		title: 'Passport & Visa Requirements',
		body: 'Your passport must be valid for at least 6 months after your return. We are not responsible for visa delays or rejections.',
	},
	{
		id: 'liability',
		title: 'Liability',
		body: 'We are agents only. We are not responsible for services provided by airlines, hotels, or transport companies.',
	},
	{
		id: 'travel-insurance',
		title: 'Travel Insurance',
		body: 'You must have full travel insurance. It should cover medical help, cancellations, and your belongings.',
	},
	{
		id: 'events-beyond-our-control',
		title: 'Events Beyond Our Control',
		body: 'We are not responsible for delays or cancellations caused by events like bad weather, strikes, or political issues.',
	},
	{
		id: 'complaints',
		title: 'Complaints',
		body: 'Tell us right away if there is an issue during your trip. You can also write to us within 15 days after returning.',
	},
	{
		id: 'data-protection',
		title: 'Data Protection',
		body: 'We collect your details based on UK laws. We keep your data safe and follow our privacy policy.',
	},
	{
		id: 'atol-protection',
		title: 'ATOL Protection',
		body: 'Our flight packages are ATOL-protected. You will get an ATOL Certificate to confirm this.',
	},
	{
		id: 'governing-law',
		title: 'Governing Law',
		body: 'These terms follow English law. Any disputes will go through the UK courts.',
	},
];

const bookingConditions = [
	`All ticket(s) booked through us are non-changeable and non-refundable.`,
	`All upfront deposits are non-refundable.`,
	`Please note that it is the passenger’s responsibility to ensure that the outstanding balance payment is paid within the due date. Failure to do so will result in the cancellation of your booking and forfeiting of the upfront deposit. Please ensure to update us about any payments that you make.`,
	`Cancellations / Refunds are subject to the guidelines / restrictions imposed by the airline company, less our administration charge. Refunds are normally processed within 3-6 months after the request. Refunds will not be paid out until received from the relevant airline/supplier.`,
	`All changes / amendments are subject to fare restrictions / availability of seats at the time of making an amendment.`,
	`All quotes are subject to availability and are not guaranteed until the ticket(s) have been issued. This applies even if full payment has been made, as airline fares and seat availability change on an ongoing basis. Ticket(s) are generally issued within 48-72 hours upon receipt of full payment. For travel on the following day, tickets will be issued within 12-24 hours. If you do not receive your tickets within these time periods, please contact us straightaway.`,
	`As airlines prefer e-tickets as the mode of travel, no paper tickets will be issued.`,
	`Passenger(s) are requested to reconfirm their booking(s) with the travel agency or airline company 72 hours prior to the flight departure time to obtain information about any last-minute changes, irrespective of the airline’s guidelines.`,
	`Passenger(s) are advised to check-in at least 3 hours prior to the flight departure time for international flights, and 2 hours for domestic flights.`,
	`It is your responsibility to ensure that all your travel documents are correct and valid for travel. This includes your e-ticket, passport, visa (if required), travel insurance (if required), and any additional travel document(s).`,
	`We accept no liability if you are denied boarding or refused entry into any country due to failure on your part to carry the correct passport, visa, or other required documents. Travelers must ensure their passport is valid for at least 6 months from their return date of travel.`,
	`The Umrah visa process may take up to 2 weeks. We hold no responsibility for any delays or refusals by Saudi authorities. The visa price can change without prior notice.`,
	`Umrah package once booked and confirmed after receiving payment is non-changeable and non-refundable.`,
	`While we will make every effort to meet passenger requirements, an alternate hotel with a similar type of room may need to be offered, with any rate difference charged accordingly.`,
	`2 children below 5 years can be accommodated free with the parents’ room, but you must pay directly to the hotel for breakfast. We will make every effort to meet the departure/arrival dates of transportation and accommodation requirements, but we reserve the right to make minor adjustments due to availability constraints.`,
	`Rooms, rates, and airfares are subject to availability and may change at the time of booking.`,
	`We hold no responsibility if any supplier changes your hotel after confirmation due to any reason.`,
	`We accept no liability if a new law or tax is implemented by Saudi authorities; passengers must comply with that. If you do not like the accommodation pre-reserved by your travel consultant, please note that issues related to the hotel rooms, such as cleanliness or maintenance, should be addressed by the hotel management. The agent may not have access to resolve such issues.`,
	`All business-to-business transactions carried out on a credit card will attract a 3% surcharge above the amount. This surcharge is non-refundable in the event of a refund. Transactions carried out on a debit card are free from any surcharge. Documents such as passport copies or card details may be requested to verify unsuccessful or unauthorized payments.`,
	`By responding to e-mail correspondence, you confirm that you have accepted and understood all the terms and conditions governing your booking with us.`,
	`When you receive an invoice you are liable to reply to the e-mail confirming: this is the itinerary you require; you have checked all details and understand the full terms and conditions of your booking; you accept responsibility for the validity of your travel documents, including passports, visas, and health requirements; and you authorize us to proceed with your reservation. This quotation is only valid upon receipt of a deposit or full payment unless otherwise specified.`,
];
---

<Layout
	title="Terms & Conditions — Blessed Tours"
	description="Read the Blessed Tours terms and conditions for bookings, payments, cancellations, travel documents, ATOL protection, and website use."
>
	<main class="landing-page">
		<SiteHeader />

		<section class="section-block px-4 pt-16 pb-8 sm:px-6 sm:pt-20 sm:pb-14 lg:px-8 lg:pt-24">
			<div class="mx-auto max-w-7xl" data-motion-root data-motion-trigger="load">
				<div class="grid gap-8 lg:grid-cols-[0.72fr_0.28fr] lg:items-end">
					<div class="max-w-3xl">
						<p
							class="mb-4 inline-flex rounded-full border border-white/15 bg-white/[0.06] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-wider text-gold-400 backdrop-blur-sm"
							data-motion-item="up"
							data-motion-delay="0"
						>
							Legal information
						</p>
						<h1
							class="font-display text-[2.5rem] leading-[0.98] tracking-tight text-ink-50 sm:text-5xl lg:text-[4rem]"
							data-motion-item="up"
							data-motion-delay="75"
						>
							Terms & Conditions
						</h1>
						<p
							class="mt-5 max-w-2xl font-sans text-base leading-relaxed text-ink-300 sm:text-lg"
							data-motion-item="up"
							data-motion-delay="150"
						>
							This website is run by a UK-based travel company. By using this site, you agree to
							follow the terms and conditions listed here. “We”, “us”, or “our” means the
							company, and “you” or “your” means anyone using the website.
						</p>
					</div>

					<div
						class="rounded-3xl border border-white/10 bg-white/[0.05] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] backdrop-blur-sm"
						data-motion-item="up"
						data-motion-delay="225"
					>
						<p class="font-sans text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-gold-400">
							Applies to
						</p>
						<p class="mt-2 font-display text-2xl leading-tight text-ink-50">Website use & bookings</p>
						<p class="mt-3 font-sans text-sm leading-relaxed text-ink-400">
							These terms cover enquiries, bookings, payments, documents, travel arrangements, and
							legal responsibilities.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="section-block section-block--divider px-4 py-8 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
			<div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[18rem_1fr] lg:gap-10">
				<aside class="min-w-0 lg:sticky lg:top-28 lg:self-start" aria-label="Terms sections">
					<div
						class="min-w-0 rounded-3xl border border-white/10 bg-white/[0.04] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] backdrop-blur-sm sm:p-4"
						data-motion-root
						data-motion-trigger="inview"
					>
						<p
							class="px-2 font-sans text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-gold-400"
							data-motion-item="up"
							data-motion-delay="0"
						>
							On this page
						</p>
						<nav class="-mx-1 mt-3 flex min-w-0 gap-2 overflow-x-auto px-1 pb-1 lg:mx-0 lg:grid lg:gap-1 lg:overflow-visible lg:px-0 lg:pb-0">
							{
								termsSections.map((section, index) => (
									<a
										href={`#${section.id}`}
										class="max-w-[78vw] shrink-0 truncate rounded-full border border-white/10 bg-white/[0.03] px-3 py-2 font-sans text-sm text-ink-300 transition-colors duration-300 hover:bg-white/[0.06] hover:text-gold-300 lg:max-w-none lg:rounded-xl lg:border-0 lg:bg-transparent lg:px-2.5"
										data-motion-item="up"
										data-motion-delay={String(75 + index * 25)}
									>
										{section.title}
									</a>
								))
							}
							<a
								href="#booking-and-travel-conditions"
								class="max-w-[78vw] shrink-0 truncate rounded-full border border-white/10 bg-white/[0.03] px-3 py-2 font-sans text-sm text-ink-300 transition-colors duration-300 hover:bg-white/[0.06] hover:text-gold-300 lg:max-w-none lg:rounded-xl lg:border-0 lg:bg-transparent lg:px-2.5"
								data-motion-item="up"
								data-motion-delay="500"
							>
								Booking & Travel Conditions
							</a>
						</nav>
					</div>
				</aside>

				<div class="min-w-0" data-motion-root data-motion-trigger="inview">
					<div class="grid gap-4">
						{
							termsSections.map((section, index) => (
								<article
									id={section.id}
									class="scroll-mt-28 rounded-3xl border border-white/10 bg-white/[0.045] p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm transition-colors duration-300 hover:border-gold-500/25 hover:bg-white/[0.06] sm:p-6"
									data-motion-item="up"
									data-motion-delay={String(Math.min(index * 40, 500))}
								>
									<div class="grid gap-4 sm:grid-cols-[3rem_1fr] sm:gap-5">
										<span class="inline-flex size-11 items-center justify-center rounded-2xl border border-gold-500/25 bg-gold-500/10 font-sans text-sm font-bold text-gold-300">
											{String(index + 1).padStart(2, '0')}
										</span>
										<div class="min-w-0">
											<h2 class="break-words font-display text-xl leading-tight text-ink-50 sm:text-2xl">
												{section.title}
											</h2>
											<p class="mt-3 max-w-3xl break-words font-sans text-[0.9375rem] leading-relaxed text-ink-300 sm:text-base">
												{section.body}
											</p>
										</div>
									</div>
								</article>
							))
						}
					</div>

					<article
						id="booking-and-travel-conditions"
						class="mt-4 min-w-0 max-w-full scroll-mt-28 overflow-hidden rounded-3xl border border-gold-500/20 bg-white/[0.045] p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm sm:p-6"
						data-motion-item="up"
						data-motion-delay="500"
					>
						<div class="grid gap-4 sm:grid-cols-[3rem_1fr] sm:gap-5">
							<span class="inline-flex size-11 items-center justify-center rounded-2xl border border-gold-500/25 bg-gold-500/10 font-sans text-sm font-bold text-gold-300">
								16
							</span>
							<div class="min-w-0 max-w-full">
								<h2 class="break-words font-display text-xl leading-tight text-ink-50 sm:text-2xl">
									Booking & Travel Conditions
								</h2>
								<p class="mt-3 max-w-full break-words font-sans text-[0.9375rem] leading-relaxed text-ink-300 sm:text-base">
									The following conditions apply to bookings, flights, Umrah packages, payments,
									travel documents, amendments, cancellations, and supplier arrangements.
								</p>
								<ol class="mt-5 grid gap-3">
									{
										bookingConditions.map((condition, index) => (
											<li class="grid min-w-0 gap-3 rounded-2xl border border-white/10 bg-white/[0.04] p-3 sm:grid-cols-[2.25rem_1fr] sm:p-4">
												<span class="inline-flex size-8 shrink-0 items-center justify-center rounded-xl border border-gold-500/25 bg-gold-500/10 font-sans text-xs font-bold text-gold-300">
													{String(index + 1).padStart(2, '0')}
												</span>
												<p class="min-w-0 max-w-full break-words font-sans text-sm leading-relaxed text-ink-300 sm:text-[0.9375rem]">
													{condition}
												</p>
											</li>
										))
									}
								</ol>
							</div>
						</div>
					</article>

					<div
						class="mt-6 overflow-hidden rounded-3xl border border-gold-500/25 bg-gold-500/10 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] sm:p-7"
						data-motion-item="up"
						data-motion-delay="525"
					>
						<p class="font-display text-2xl leading-tight text-ink-50">Questions about these terms?</p>
						<p class="mt-3 max-w-2xl font-sans text-base leading-relaxed text-ink-300">
							For any questions or concerns regarding our Terms and Conditions, please do not
							hesitate to contact us.
						</p>
						<div class="mt-5 flex flex-col gap-3 sm:flex-row">
							<a
								href="tel:02037731172"
								class="inline-flex w-full items-center justify-center rounded-full border border-gold-500/35 bg-gold-500/15 px-5 py-2.5 font-sans text-sm font-semibold text-gold-300 transition-all duration-300 hover:-translate-y-0.5 hover:bg-gold-500/22 active:translate-y-0 sm:w-auto"
							>
								Call 0203-773-1172
							</a>
							<a
								href="mailto:info@blessedtours.co.uk"
								class="inline-flex w-full items-center justify-center rounded-full border border-white/15 bg-white/[0.05] px-5 py-2.5 font-sans text-sm font-semibold text-ink-50 transition-all duration-300 hover:-translate-y-0.5 hover:border-gold-500/35 hover:text-gold-300 active:translate-y-0 sm:w-auto"
							>
								Email us
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
