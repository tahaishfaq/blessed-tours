---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { footerContact, footerSocialLinks } from '../data/footer';
import { phone, whatsapp } from '../data/navigation';

const contactCards = [
	{
		title: 'Call our team',
		label: phone.label,
		href: phone.href,
		description: 'Speak with us about Hajj, Umrah, flights, hotels, visas, and group travel.',
	},
	{
		title: 'Message on WhatsApp',
		label: whatsapp.label,
		href: whatsapp.href,
		description: 'Send your travel dates, number of passengers, and package preference.',
	},
	{
		title: 'Email enquiries',
		label: footerContact.email.label,
		href: footerContact.email.href,
		description: 'Use email for detailed package requests, documents, and follow-up questions.',
	},
];

const contactSocialLinks = [
	{
		label: 'WhatsApp',
		href: whatsapp.href,
		icon: 'whatsapp',
	},
	...footerSocialLinks,
];
---

<Layout
	title="Contact Us — Blessed Tours"
	description="Contact Blessed Tours UK for Hajj, Umrah, flights, hotels, transport, visa support, and Islamic travel enquiries."
>
	<main class="landing-page">
		<SiteHeader />

		<section class="section-block px-4 pt-16 pb-12 sm:px-6 sm:pt-20 sm:pb-16 lg:px-8 lg:pt-24 lg:pb-20">
			<div class="mx-auto max-w-7xl" data-motion-root data-motion-trigger="load">
				<div class="mx-auto max-w-4xl text-center">
					<p
						class="mb-4 inline-flex rounded-full border border-white/15 bg-white/[0.06] px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-wider text-gold-400 backdrop-blur-sm"
						data-motion-item="up"
						data-motion-delay="0"
					>
						Contact Blessed Tours
					</p>
					<h1
						class="mx-auto max-w-3xl font-display text-4xl leading-none tracking-tight text-ink-50 sm:text-5xl lg:text-[4.5rem]"
						data-motion-item="up"
						data-motion-delay="75"
					>
						Plan your sacred journey with a team that listens.
					</h1>
					<p
						class="mx-auto mt-6 max-w-2xl font-sans text-base leading-relaxed text-ink-300 sm:text-lg"
						data-motion-item="up"
						data-motion-delay="150"
					>
						Tell us where you want to travel, when you want to depart, and what support you need.
						Our UK team can help with Hajj, Umrah, flights, hotels, transport, visas, and tailored
						group arrangements.
					</p>
				</div>

				<div
					class="relative mx-auto mt-10 max-w-4xl overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.055] p-4 shadow-[0_24px_70px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.12)] backdrop-blur-xl sm:p-5 lg:p-6"
					data-motion-item="scale"
					data-motion-delay="225"
				>
					<div
						class="pointer-events-none absolute -top-px right-10 left-10 h-px bg-gradient-to-r from-transparent via-white/40 to-transparent"
						aria-hidden="true"
					></div>
					<div class="rounded-[1.5rem] border border-white/10 bg-ink-950/35 p-4 sm:p-6 lg:p-7">
						<div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
							<div>
								<p class="font-sans text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-gold-400">
									Quick enquiry
								</p>
								<h2 class="mt-2 font-display text-3xl leading-tight text-ink-50">
									Request a call back
								</h2>
							</div>
							<p class="max-w-sm font-sans text-sm leading-relaxed text-ink-400 md:text-right">
								Share a few details and our team will guide you towards the right package.
							</p>
						</div>
					<form class="mt-7 grid gap-4" action="#" method="post">
						<div class="grid gap-2">
							<label for="contact-name" class="font-sans text-sm font-semibold text-ink-100">
								Full name
							</label>
							<input
								id="contact-name"
								name="name"
								type="text"
								autocomplete="name"
								required
								class="h-12 rounded-xl border border-white/50 bg-white/92 px-4 font-sans text-sm text-ink-950 shadow-[inset_0_1px_0_rgba(255,255,255,0.65)] outline-none transition-all duration-300 placeholder:text-ink-400 hover:bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-500/25"
								placeholder="Your name"
							/>
						</div>
						<div class="grid gap-4 sm:grid-cols-2">
							<div class="grid gap-2">
								<label for="contact-phone" class="font-sans text-sm font-semibold text-ink-100">
									Phone
								</label>
								<input
									id="contact-phone"
									name="phone"
									type="tel"
									autocomplete="tel"
									required
									class="h-12 rounded-xl border border-white/50 bg-white/92 px-4 font-sans text-sm text-ink-950 shadow-[inset_0_1px_0_rgba(255,255,255,0.65)] outline-none transition-all duration-300 placeholder:text-ink-400 hover:bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-500/25"
									placeholder="Phone number"
								/>
							</div>
							<div class="grid gap-2">
								<label for="contact-email" class="font-sans text-sm font-semibold text-ink-100">
									Email
								</label>
								<input
									id="contact-email"
									name="email"
									type="email"
									autocomplete="email"
									class="h-12 rounded-xl border border-white/50 bg-white/92 px-4 font-sans text-sm text-ink-950 shadow-[inset_0_1px_0_rgba(255,255,255,0.65)] outline-none transition-all duration-300 placeholder:text-ink-400 hover:bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-500/25"
									placeholder="Email address"
								/>
							</div>
						</div>
						<div class="grid gap-2">
							<label for="contact-service" class="font-sans text-sm font-semibold text-ink-100">
								Service interested in
							</label>
							<div class="relative">
								<select
									id="contact-service"
									name="service"
									required
									class="contact-service-select h-12 w-full cursor-pointer appearance-none rounded-xl border border-white/50 bg-white/92 px-4 pr-10 font-sans text-sm text-ink-400 shadow-[inset_0_1px_0_rgba(255,255,255,0.65)] outline-none transition-all duration-300 hover:bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-500/25"
									data-contact-service-select
								>
									<option value="" disabled selected>Select service</option>
									<option value="Umrah Packages">Umrah Packages</option>
									<option value="Hajj Packages">Hajj Packages</option>
									<option value="Flights">Flights</option>
									<option value="Holiday Packages">Holiday Packages</option>
									<option value="Visa Support">Visa Support</option>
									<option value="Group Travel">Group Travel</option>
								</select>
								<svg
									class="pointer-events-none absolute top-1/2 right-3 size-4 -translate-y-1/2 text-ink-500"
									viewBox="0 0 20 20"
									fill="currentColor"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.24 4.5a.75.75 0 01-1.08 0l-4.24-4.5a.75.75 0 01.02-1.06z"
										clip-rule="evenodd"></path>
								</svg>
							</div>
						</div>
						<div class="grid gap-2">
							<label for="contact-message" class="font-sans text-sm font-semibold text-ink-100">
								Message
							</label>
							<textarea
								id="contact-message"
								name="message"
								rows="4"
								class="resize-none rounded-xl border border-white/50 bg-white/92 px-4 py-3 font-sans text-sm text-ink-950 shadow-[inset_0_1px_0_rgba(255,255,255,0.65)] outline-none transition-all duration-300 placeholder:text-ink-400 hover:bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-500/25"
								placeholder="Tell us your preferred dates, passengers, and package type"
							></textarea>
						</div>
						<button
							type="submit"
							class="mt-1 inline-flex h-12 items-center justify-center rounded-full border border-gold-400/50 bg-gold-500/95 px-6 font-sans text-sm font-bold tracking-wide text-ink-950 shadow-[0_10px_28px_rgba(0,0,0,0.28),inset_0_1px_0_rgba(255,255,255,0.35)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-gold-400 active:translate-y-0"
						>
							Send enquiry
						</button>
					</form>
					</div>
				</div>
			</div>
		</section>

		<section class="section-block section-block--divider px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
			<div class="mx-auto max-w-7xl" data-motion-root data-motion-trigger="inview">
				<div class="grid gap-4 md:grid-cols-3">
					{
						contactCards.map((card, index) => (
							<a
								href={card.href}
								target={card.href.startsWith('http') ? '_blank' : undefined}
								rel={card.href.startsWith('http') ? 'noopener noreferrer' : undefined}
								class="group rounded-3xl border border-white/10 bg-white/[0.045] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm transition-[border-color,background-color,transform] duration-300 hover:-translate-y-1 hover:border-gold-500/30 hover:bg-white/[0.065] sm:p-6"
								data-motion-item="up"
								data-motion-delay={String(index * 90)}
							>
								<span class="inline-flex size-11 items-center justify-center rounded-2xl border border-gold-500/25 bg-gold-500/10 text-gold-300 transition-transform duration-300 group-hover:scale-105">
									<svg class="size-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
										<path
											d="M5 10h10M11 6l4 4-4 4"
											stroke="currentColor"
											stroke-width="1.8"
											stroke-linecap="round"
											stroke-linejoin="round"></path>
									</svg>
								</span>
								<h2 class="mt-5 font-display text-2xl leading-tight text-ink-50">{card.title}</h2>
								<p class="mt-1 font-sans text-sm font-semibold text-gold-300">{card.label}</p>
								<p class="mt-3 font-sans text-sm leading-relaxed text-ink-400">
									{card.description}
								</p>
							</a>
						))
					}
				</div>

				<div class="mt-8 rounded-3xl border border-white/10 bg-white/[0.045] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-sm sm:p-7">
					<div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
						<div>
							<p class="font-sans text-xs font-semibold uppercase tracking-[0.14em] text-gold-400">
								Social media
							</p>
							<h2 class="mt-2 font-display text-2xl leading-tight text-ink-50">
								Follow Blessed Tours online
							</h2>
						</div>
						<div class="flex flex-wrap gap-2.5">
							{
								contactSocialLinks.map((link) => (
									<a
										href={link.href}
										target="_blank"
										rel="noopener noreferrer"
										class:list={[
											'inline-flex items-center gap-2 rounded-full border px-4 py-2.5 font-sans text-sm font-semibold transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0',
											link.icon === 'whatsapp'
												? 'border-[#25D366]/35 bg-[#25D366]/10 text-[#5dde7a] hover:border-[#25D366]/55 hover:bg-[#25D366]/16'
												: 'border-white/12 bg-white/[0.04] text-ink-200 hover:border-gold-500/45 hover:bg-gold-500/10 hover:text-gold-300',
										]}
									>
										{link.icon === 'whatsapp' && (
											<svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
												<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
											</svg>
										)}
										{link.icon === 'tiktok' && (
											<svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
												<path d="M16.6 5.82a5.95 5.95 0 003.57 1.21V10a8.86 8.86 0 01-3.55-.75v5.61A6.14 6.14 0 1110.5 8.72c.37 0 .74.03 1.1.1v3.05a3.11 3.11 0 00-1.1-.2 3.16 3.16 0 103.15 3.16V2h2.95v3.82z" />
											</svg>
										)}
										{link.icon === 'instagram' && (
											<svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
												<rect x="4" y="4" width="16" height="16" rx="4.5" />
												<circle cx="12" cy="12" r="3.6" />
												<path stroke-linecap="round" d="M17.3 6.9h.01" />
											</svg>
										)}
										{link.icon === 'facebook' && (
											<svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
												<path d="M14.2 8.15V6.9c0-.62.42-.77.72-.77h1.83V3.18L14.23 3.17c-2.8 0-3.44 2.1-3.44 3.44v1.54H9.17v3.03h1.62V21h3.41v-9.82h2.3l.31-3.03H14.2z" />
											</svg>
										)}
										{link.icon === 'linkedin' && (
											<svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
												<path d="M6.94 8.9H3.8V20h3.14V8.9zM5.37 4a1.82 1.82 0 100 3.64A1.82 1.82 0 005.37 4zm6.54 4.9H8.9V20h3.01v-5.82c0-1.53.29-3.02 2.19-3.02 1.87 0 1.9 1.75 1.9 3.12V20h3.01v-6.45c0-3.17-.68-5.6-4.38-5.6-1.78 0-2.97.98-3.46 1.9h-.04V8.9z" />
											</svg>
										)}
										{link.label}
									</a>
								))
							}
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	document.querySelectorAll<HTMLSelectElement>('[data-contact-service-select]').forEach((select) => {
		const syncSelectColor = () => {
			select.classList.toggle('text-ink-400', select.value === '');
			select.classList.toggle('text-ink-950', select.value !== '');
		};

		select.addEventListener('change', syncSelectColor);
		syncSelectColor();
	});
</script>
